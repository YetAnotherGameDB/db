			<br>&nbsp;<u><i><font color="#FFFF00">BATTLING CONTROLS:</font></i></u><br>
                  &nbsp; Move battler -
                  <font color="#00FF00">&nbsp;D-Pad</font>		
                  <br>&nbsp; Swing -
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Bunt -
                  <font color="#00FF00">&nbsp;Square Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">FIELDING AND THROWING CONTROLS:</font></i></u><br>
                  &nbsp; Move fielder -
                  <font color="#00FF00">&nbsp;D-Pad</font>		
                  <br>&nbsp; Throw ball -
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Touch base -
                  <font color="#00FF00">&nbsp;Circle Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">BASE RUNNING CONTROLS:</font></i></u><br>
                  &nbsp; Advance runner -
                  <font color="#00FF00">&nbsp;D-Pad + X Button</font>		
                  <br>&nbsp; Return runner -
                  <font color="#00FF00">&nbsp;D-Pad + Circle Button</font>
                  <br>&nbsp; Steal base -
                  <font color="#00FF00">&nbsp;D-Pad + Triangle Button</font>
                  <br>&nbsp; Slide -
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; All runners advance -
                  <font color="#00FF00">&nbsp;L1 or L2 Button</font>
                  <br>&nbsp; All runners return -
                  <font color="#00FF00">&nbsp;R1 or R2 Button</font><br><br>		
				  &nbsp;</td>
	 </tr>
