<!-- Game Controls Sectional -->

<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">BASIC CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Activate encounter cancel system:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Uses lead characters tools, activates search system:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Talk to people / Investigate item / Solve puzzles / hold to dash:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Display menu screen:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Display world map:
                  <font color="#00FF00">&nbsp;Select Button</font>
                  <br>&nbsp; Rotate camera clockwise:
                  <font color="#00FF00">&nbsp;L1 Button</font>
                  <br>&nbsp; Rotate camera counterclockwise:
                  <font color="#00FF00">&nbsp;R1 Button</font>
                  <br>&nbsp; Change characters / Tools:
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">BATTLE AND MENU CONTROLS:</font></i></u><br>
                  &nbsp; Moves the cursor to the desired item:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Cancel a menu item:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Select a menu item:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Display help messages with an explanation of a certian menu item or attack:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Toggle character:
                  <font color="#00FF00">&nbsp;L1 or L2 Button</font>
                  <br>&nbsp; Scroll page up or down:
                  <font color="#00FF00">&nbsp;R1 or R2 Button</font><br><br>
        &nbsp;</td>
	 </tr>
	</table>
