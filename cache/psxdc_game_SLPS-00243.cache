	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">BASIC CONTROLS:</font></i></u><br>
                  &nbsp; Steer:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Accelerate:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Nitrous burst (nitro bikes only):
                  <font color="#00FF00">&nbsp;X Button (twice)</font>
                  <br>&nbsp; Brake:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Dismount:
                  <font color="#00FF00">&nbsp;Slow your bike down until you stop, then press Up + R1 + L1 Button</font>
                  <br>&nbsp; Lean left or right:
                  <font color="#00FF00">&nbsp;L1 or R1 Button</font>
                  <br>&nbsp; Punch / use weapon:
                  <font color="#00FF00">&nbsp;R2 or Circle Button</font>
                  <br>&nbsp; Backhand punch:
                  <font color="#00FF00">&nbsp;Circle Button + D-Pad Up</font>
                  <br>&nbsp; Kick:
                  <font color="#00FF00">&nbsp;L2 or Circle Button + D-Pad Down</font>
                  <br>&nbsp; Grab weapon from opponent:
                  <font color="#00FF00">&nbsp;R2 or Circle Button</font>
                  <br>&nbsp; Pause game:
                  <font color="#00FF00">&nbsp;Start Button</font>
                  <br>&nbsp; Quit game:
                  <font color="#00FF00">&nbsp;Start + Select Button</font><br><br>
     &nbsp;</td>
	 </tr>
	</table>
