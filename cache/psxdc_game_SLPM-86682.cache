		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">GENERAL CONTROLS:</font></i></u><br>
                  &nbsp; Speed up -
                  <font color="#00FF00">&nbsp;D-Pad Up</font>				  
                  <br>&nbsp; Brake -
                  <font color="#00FF00">&nbsp;D-Pad Down</font>
                  <br>&nbsp; Turn left or right -
                  <font color="#00FF00">&nbsp;D-Pad Left or Right</font>				  
                  <br>&nbsp; Spin right -
                  <font color="#00FF00">&nbsp;R1 or R2 Button</font>				  
                  <br>&nbsp; Spin left -
                  <font color="#00FF00">&nbsp;L1 or L2 Button</font>
                  <br>&nbsp; Pause game -
                  <font color="#00FF00">&nbsp;Start Button</font><br>
				  <br>&nbsp;<u><i><font color="#FFFF00">GROUND MOVES CONTROLS:</font></i></u><br>
                  &nbsp; Bunnyhop -
                  <font color="#00FF00">&nbsp;X Button</font>			
                  <br>&nbsp; Grind -
                  <font color="#00FF00">&nbsp;D-Pad Angle + Triangle Button</font>				  
                  <br>&nbsp; 90 Degree Angle Stalls -
                  <font color="#00FF00">&nbsp;D-Pad + Triangle Button</font>
                  <br>&nbsp; Double peg grind -
                  <font color="#00FF00">&nbsp;Triangle Button</font><br>				  
			<br>&nbsp;<u><i><font color="#FFFF00">AIR MOVES CONTROLS:</font></i></u><br>
                  &nbsp; Big air trick -
                  <font color="#00FF00">&nbsp;D-Pad + Square Button</font>			
                  <br>&nbsp; Modifier trick -
                  <font color="#00FF00">&nbsp;D-Pad + Circle Button</font>
                  <br>&nbsp; Footplant, walltap -
                  <font color="#00FF00">&nbsp;D-Pad + X Button</font><br><br>
		&nbsp;</td>
	 </tr>
	</table>
