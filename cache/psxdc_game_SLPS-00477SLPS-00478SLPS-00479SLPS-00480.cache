                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Accelerate:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Display world map:
                  <font color="#00FF00">&nbsp;Select Button</font>
                  <br>&nbsp; Full stop:
                  <font color="#00FF00">&nbsp;X + L1 + L2 Button</font>
                  <br>&nbsp; Afterburner:
                  <font color="#00FF00">&nbsp;L2 + R2 Button</font>
                  <br>&nbsp; Cycle weapons:
                  <font color="#00FF00">&nbsp;L1 + Square Button</font>
                  <br>&nbsp; Cycle guns:
                  <font color="#00FF00">&nbsp;L1 + Circle Button</font>
                  <br>&nbsp; Cycle targets:
                  <font color="#00FF00">&nbsp;L1 + X Button</font>
                  <br>&nbsp; Lock targets:
                  <font color="#00FF00">&nbsp;L1 + Triangle Button</font>
                  <br>&nbsp; Autopilot:
                  <font color="#00FF00">&nbsp;L1 + L2 + R1 + R2 Button</font>
                  <br>&nbsp; Comms select:
                  <font color="#00FF00">&nbsp;Select Button + D-Pad Left/Right</font>
                  <br>&nbsp; Nav Map:
                  <font color="#00FF00">&nbsp;Select Button + L2 Button</font>
                  <br>&nbsp; Eject:
                  <font color="#00FF00">&nbsp;L1 + L2 + R1 + R2 + Select + Start Button</font>
                  <br>&nbsp; Cloak:
                  <font color="#00FF00">&nbsp;L1 + R2 Button</font><br><br>
