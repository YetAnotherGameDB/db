<!-- Game Controls Sectional -->

<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">BASIC CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick</font>
                  <br>&nbsp; Grapple attacks:
                  <font color="#00FF00">&nbsp;D-Pad + Circle Button</font>
                  <br>&nbsp; Striking attacks:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Run, slide into ring:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Irish whip:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Counter, reverse, grab belt from ladder:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Grab weapon, drop weapon, set up table or coffin, tag partner:
                  <font color="#00FF00">&nbsp;R1 Button</font>
                  <br>&nbsp; Finishing moves:
                  <font color="#00FF00">&nbsp;L1 Button</font>
                  <br>&nbsp; Climb turnbuckle or ladder:
                  <font color="#00FF00">&nbsp;D-Pad + Triangle Button</font>
                  <br>&nbsp; Climb out of ring:
                  <font color="#00FF00">&nbsp;D-Pad + R1 Button</font>
                  <br>&nbsp; Pin opponent:
                  <font color="#00FF00">&nbsp;D-Pad + Circle Button</font>
                  <br>&nbsp; Pause game:
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">OPPONENT ON MAT CONTROLS:</font></i></u><br>
                  &nbsp; Upper and lower body holds:
                  <font color="#00FF00">&nbsp;D-Pad Left, Up, or Right + Circle Button</font>
                  <br>&nbsp; Pin opponent:
                  <font color="#00FF00">&nbsp;D-Pad + Circle Button</font>
                  <br>&nbsp; Raise opponent (facing):
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; raise opponent (behind):
                  <font color="#00FF00">&nbsp;Circle Button (twice)</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">ROPE ATTACKS CONTROLS:</font></i></u><br>
                  &nbsp; Smack over or through ropes:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Dive through or jump over ropes:
                  <font color="#00FF00">&nbsp;D-Pad + X Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">TOP ROPE ATTACKS CONTROLS:</font></i></u><br>
                  &nbsp; Aerial attacks:
                  <font color="#00FF00">&nbsp;X Button</font><br><br>
        &nbsp;</td>
	 </tr>
	</table>
       	</td>
     </tr>
</table>

      
