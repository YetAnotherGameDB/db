		<br>&nbsp;<u><i><font color="#FFFF00">DEFENSE CONTROLS:</font></i></u><br>
            &nbsp; Move character -
            <font color="#00FF00">D-Pad or Left Analog Stick</font>	
            <br>&nbsp; Switch player -
            <font color="#00FF00">X Button</font>
            <br>&nbsp; Hand check -
            <font color="#00FF00">Circle Button</font>			
            <br>&nbsp; Steal -
            <font color="#00FF00">Square Button</font>		
            <br>&nbsp; Jump -
            <font color="#00FF00">Triangle Button</font>					
            <br>&nbsp; Direct switch / Walk -
            <font color="#00FF00">L1 Button</font>	
            <br>&nbsp; Switch player -
            <font color="#00FF00">L2 Button</font>	
            <br>&nbsp; Turbo -
            <font color="#00FF00">R1 Button</font>	
            <br>&nbsp; Face up -
            <font color="#00FF00">R2 Button</font>				
            <br>&nbsp; Pause game -
            <font color="#00FF00">Start Button</font><br>
		<br>&nbsp;<u><i><font color="#FFFF00">OFFENSE CONTROLS:</font></i></u><br>
            &nbsp; Move character -
            <font color="#00FF00">D-Pad or Left Analog Stick</font>	
            <br>&nbsp; Pass -
            <font color="#00FF00">X Button</font>
            <br>&nbsp; Shoot -
            <font color="#00FF00">Circle Button</font>			
            <br>&nbsp; Crossover -
            <font color="#00FF00">Square Button</font>		
            <br>&nbsp; Back down / Spin -
            <font color="#00FF00">Triangle Button</font>					
            <br>&nbsp; Direct pass/walk -
            <font color="#00FF00">L1 Button</font>	
            <br>&nbsp; Direct shoot -
            <font color="#00FF00">L2 Button</font>	
            <br>&nbsp; Turbo -
            <font color="#00FF00">R1 Button</font>	
            <br>&nbsp; Stutter step / Fakes -
            <font color="#00FF00">R2 Button</font>				
            <br>&nbsp; Pause game -
            <font color="#00FF00">Start Button</font><br><br>
			&nbsp;</td>
