	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">GAME CONTROLS:</font></i></u><br>
                  &nbsp; Move character -
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick</font>		
                  <br>&nbsp; Boost Jump -
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Dash -
                  <font color="#00FF00">&nbsp;X Button + D-Pad</font>				  
                  <br>&nbsp; Activate doors or switches, use left arm weapon -
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Fire weapon -
                  <font color="#00FF00">&nbsp;Square Button</font>		
                  <br>&nbsp; Select weapon -
                  <font color="#00FF00">&nbsp;Triangle Button</font>		
                  <br>&nbsp; Strafe left or right -
                  <font color="#00FF00">&nbsp;L1 or R1 Button</font>		
                  <br>&nbsp; Look up -
                  <font color="#00FF00">&nbsp;L2 Button</font>						  
                  <br>&nbsp; Look down -
                  <font color="#00FF00">&nbsp;R2 Button</font>						  
                  <br>&nbsp; Display map -
                  <font color="#00FF00">&nbsp;Select Button</font>
                  <br>&nbsp; Pause game -
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">MAP SCREEN CONTROLS:</font></i></u><br>
                  &nbsp; Move -
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick</font>		
                  <br>&nbsp; Shift map down -
                  <font color="#00FF00">&nbsp;X Button</font>				  
                  <br>&nbsp; Shift map right -
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Shift map left -
                  <font color="#00FF00">&nbsp;Square Button</font>		
                  <br>&nbsp; Shift map up -
                  <font color="#00FF00">&nbsp;Triangle Button</font>		
                  <br>&nbsp; Zoom out or in -
                  <font color="#00FF00">&nbsp;L1 or R1 Button</font>		
                  <br>&nbsp; Return to game -
                  <font color="#00FF00">&nbsp;Select Button</font><br><br>				  
				  &nbsp;</td>
