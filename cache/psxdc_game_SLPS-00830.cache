		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">GENERAL CONTROLS:</font></i></u><br>
                  &nbsp; Move plane - 
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick</font>
                  <br>&nbsp; Fire machine guns - 
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Fire missiles - 
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Ground map display - 
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Change the lock on target - 
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Left or right yaw - 
                  <font color="#00FF00">&nbsp;L2 or R2 Button</font>
                  <br>&nbsp; Accelerate - 
                  <font color="#00FF00">&nbsp;R1 Button</font>
                  <br>&nbsp; Decelerate - 
                  <font color="#00FF00">&nbsp;L1 Button</font>
                  <br>&nbsp; Change view - 
                  <font color="#00FF00">&nbsp;Select Button</font>
                  <br>&nbsp; Pause game - 
                  <font color="#00FF00">&nbsp;Start Button</font><br><br>
        &nbsp;</td>
	 </tr>
	</table>
