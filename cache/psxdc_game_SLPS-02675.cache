<!-- Game Controls Sectional -->

<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
		<br>&nbsp;<u><i><font color="#FFFF00">BASIC CONTROLS:</font></i></u><br>
            &nbsp; Move player -
            <font color="#00FF00">D-Pad or Left Analog Stick</font>
            <br>&nbsp; Sprint -
            <font color="#00FF00">Triangle Button</font>		
            <br>&nbsp; Pause game -
            <font color="#00FF00">Start Button</font><br>
		<br>&nbsp;<u><i><font color="#FFFF00">ATTACK CONTROLS:</font></i></u><br>
            &nbsp; Pass -
            <font color="#00FF00">X Button</font>	
            <br>&nbsp; Shoot -
            <font color="#00FF00">Circle Button</font><br>
		<br>&nbsp;<u><i><font color="#FFFF00">DEFENSE CONTROLS:</font></i></u><br>
            &nbsp; Switch player -
            <font color="#00FF00">X Button</font>	
            <br>&nbsp; Conservative Tackle -
            <font color="#00FF00">Circle Button</font>		
            <br>&nbsp; Slide tackle -
            <font color="#00FF00">Square Button</font><br>
		<br>&nbsp;<u><i><font color="#FFFF00">PLAYER BALL POSSESSION CONTROLS:</font></i></u><br>
            &nbsp; Move target -
            <font color="#00FF00">D-Pad or Left Analog Stick</font>	
            <br>&nbsp; Take kick / Throw ball -
            <font color="#00FF00">X Button</font>		
            <br>&nbsp; Icon attack -
            <font color="#00FF00">Square, Triangle, or Circle Button</font>					
            <br>&nbsp; Add ballspin left/right -
            <font color="#00FF00">L2 or R2 Button (Hold)</font>
            <br>&nbsp; Toggle set pieces -
            <font color="#00FF00">Select Button</font><br>
		<br>&nbsp;<u><i><font color="#FFFF00">PLAYER DEFENSE IN DEAD BALL SITUATION CONTROLS:</font></i></u><br>
            &nbsp; Move player -
            <font color="#00FF00">D-Pad or Left Analog Stick</font>	
            <br>&nbsp; Switch player -
            <font color="#00FF00">X Button</font>		
            <br>&nbsp; Icon defend -
            <font color="#00FF00">Square, Triangle, or Circle Button</font><br>
		<br>&nbsp;<u><i><font color="#FFFF00">PENALTY KICK TAKER CONTROLS:</font></i></u><br>
            &nbsp; Target shot -
            <font color="#00FF00">D-Pad or Left Analog Stick</font>	
            <br>&nbsp; Switch player -
            <font color="#00FF00">X Button</font>		
            <br>&nbsp; Switch kicking side -
            <font color="#00FF00">Square Button</font>
            <br>&nbsp; Shoot -
            <font color="#00FF00">Circle Button</font><br>
		<br>&nbsp;<u><i><font color="#FFFF00">PENALTY KICK GOALIE CONTROLS:</font></i></u><br>
            &nbsp; Move along line/choose direction of save -
            <font color="#00FF00">D-Pad or Left Analog Stick</font>	
            <br>&nbsp; Attempt save -
            <font color="#00FF00">Square, X, or Circle Button</font><br><br>
			&nbsp;</td>
	 </tr>
	</table>
       	</td>
     </tr>
</table>

      
