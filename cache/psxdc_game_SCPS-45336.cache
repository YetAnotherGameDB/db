<!-- Game Controls Sectional -->

<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">BASIC CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Punch:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Special attack:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Change speed experience point (AI mode), change control:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Kick, change power experience point (AI mode):
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Dodge left or right:
                  <font color="#00FF00">&nbsp;L1 or R1 Button</font>
                  <br>&nbsp; Move to next assignment (training mode):
                  <font color="#00FF00">&nbsp;Select Button</font>
                  <br>&nbsp; Pause game:
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">SPECIAL ATTACKS CONTROLS:</font></i></u><br>
                  &nbsp; Ducking upper attack:
                  <font color="#00FF00">&nbsp;D-Pad Down (twice) + X Button</font>
                  <br>&nbsp; Grapple move:
                  <font color="#00FF00">&nbsp;Circle + X Button</font>
                  <br>&nbsp; Push opponent:
                  <font color="#00FF00">&nbsp;D-Pad Away (twice) + X Button</font>
                  <br>&nbsp; Sway attack:
                  <font color="#00FF00">&nbsp;D-Pad Away (twice) + Triangle Button</font>
                  <br>&nbsp; Straight dash:
                  <font color="#00FF00">&nbsp;D-Pad Down, Pad Toward + X Button</font>
                  <br>&nbsp; Dash upper:
                  <font color="#00FF00">&nbsp;D-Pad Down, Pad Away + Circle Button</font>
                  <br>&nbsp; Dash middle:
                  <font color="#00FF00">&nbsp;D-Pad Toward (twice) + Triangle Button</font>
                  <br>&nbsp; Dash ultimate:
                  <font color="#00FF00">&nbsp;D-Pad Down, Pad Away + Triangle Button</font>
                  <br>&nbsp; Upper dodge attack:
                  <font color="#00FF00">&nbsp;L1 + X Button</font>
                  <br>&nbsp; High dodge attack:
                  <font color="#00FF00">&nbsp;L1 + Circle Button</font>
                  <br>&nbsp; Knee dodge attack:
                  <font color="#00FF00">&nbsp;L1 + Triangle Button</font>
                  <br>&nbsp; Counter attack (upper):
                  <font color="#00FF00">&nbsp;D-Pad Down, Pad Away + Triangle Button</font>
                  <br>&nbsp; Counter attack (middle):
                  <font color="#00FF00">&nbsp;D-Pad Down, Pad Away + X Button</font>
                  <br>&nbsp; Counter attack (lower):
                  <font color="#00FF00">&nbsp;D-Pad Down, Pad Away + Circle Button</font><br><br>
        &nbsp;</td>
	 </tr>
	</table>
       	</td>
     </tr>
</table>

      
