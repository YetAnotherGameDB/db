<!-- Game Controls Sectional -->

<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">IN THE FIELD CONTROLS:</font></i></u><br>
                  &nbsp; Move character -
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick</font>	  
                  <br>&nbsp; Jump (double jumps can be performed after picking up a certain item) -
                  <font color="#00FF00">&nbsp;X Button</font>	
                  <br>&nbsp; Use techniques obtained by Assimilation -
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Attack with Fusion (press rapidly for 4-hit combo attack) / Assimilate / Open Treasure Chests / Read sign posts -
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Attack with Lumina / Use the power of the Five Scrolls -
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Defend (Effective only when held down while in action) / Fill up the charge gauge (press and hold while in action) -
                  <font color="#00FF00">&nbsp;R1 Button</font>				  
                  <br>&nbsp; Pause game -
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">IN THE VILLAGE CONTROLS:</font></i></u><br>
                  &nbsp; Move character -
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick</font>	  
                  <br>&nbsp; Jump -
                  <font color="#00FF00">&nbsp;X Button</font>	
                  <br>&nbsp; Talk to people / Knock on doors / Read sign posts -
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Change Viewpoint -
                  <font color="#00FF00">&nbsp;L2 or R2 Button</font>				  
                  <br>&nbsp; Pause game -
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">MENU CONTROLS:</font></i></u><br>
                  &nbsp; Move cursor -
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick</font>	  
                  <br>&nbsp; Execute / Proceed to the next dialog box or message (in shops, sub-menu screen) -
                  <font color="#00FF00">&nbsp;X Button</font>	
                  <br>&nbsp; Cancel (in shops, sub-menu screen) / Proceed to the next dialogue box or message -
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Skip voice-overs -
                  <font color="#00FF00">&nbsp;Circle Button</font><br><br>
				  &nbsp;</td>
	 </tr>
	</table>
