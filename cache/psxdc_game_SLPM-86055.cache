<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">OFFENSE CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick</font>
                  <br>&nbsp; Short Pass:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Long Pass / Centering:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Shoot:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Through Pass:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Dash:
                  <font color="#00FF00">&nbsp;R1 Button</font>
                  <br>&nbsp; Cursor Change:
                  <font color="#00FF00">&nbsp;L1 Button</font>
                  <br>&nbsp; In game strategy:
                  <font color="#00FF00">&nbsp;L2 or R2 Button</font>
                  <br>&nbsp; Score with lob kick:
                  <font color="#00FF00">&nbsp;In the penalty area hold L1 then press Square
to lob / chip the ball</font>
                  <br>&nbsp; Options menu / Pause game:
                  <font color="#00FF00">&nbsp;Select Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">DEFENSE CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick</font>
                  <br>&nbsp; Press:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Sliding:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Keeper Charge:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Dash:
                  <font color="#00FF00">&nbsp;R1 Button</font>
                  <br>&nbsp; Cursor Change:
                  <font color="#00FF00">&nbsp;L1 Button</font>
                  <br>&nbsp; In game strategy:
                  <font color="#00FF00">&nbsp;L2 or R2 Button</font>
                  <br>&nbsp; Options menu / Pause game:
                  <font color="#00FF00">&nbsp;Select Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">HEADING CONTROLS (Ball in the air):</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick</font>
                  <br>&nbsp; Heading to teammate's feet:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Heading to teammate's head:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Straight heading:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Options menu / Pause game:
                  <font color="#00FF00">&nbsp;Select Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">TEAM MANAGEMENT CONTROLS:</font></i></u><br>
                  &nbsp; Change Formation:
                  <font color="#00FF00">&nbsp;L1 or R1 Button</font>
                  <br>&nbsp; Change Libero, Line, or Sweeper style:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Change Auto / Manual cursor change:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Strate:
                  <font color="#00FF00">&nbsp;Select Button</font><br><br>
        &nbsp;</td>
	 </tr>
	</table>
