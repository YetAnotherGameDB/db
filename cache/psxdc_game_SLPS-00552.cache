	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
		<br>&nbsp;<u><i><font color="#FFFF00">BASIC CONTROLS:</font></i></u><br>
            &nbsp; Move cursor -
            <font color="#00FF00">D-Pad</font>	
            <br>&nbsp; Move, shoot, inspect friendly / enemy troops -
            <font color="#00FF00">X Button</font>				
            <br>&nbsp; Exits all menus without making a selection -
            <font color="#00FF00">Square Button</font>	
            <br>&nbsp; Takes you from the tactical map to menus where you can set prefrences, issue command, also used to accept choices and return to game -
            <font color="#00FF00">Circle Button</font>				
            <br>&nbsp; Zoom in -
            <font color="#00FF00">Triangle Button (Held) + L1 Button</font>
            <br>&nbsp; Zoom out -
            <font color="#00FF00">Triangle Button (Held) + R1 Button</font>			
            <br>&nbsp; Next -
            <font color="#00FF00">R1 Button</font>
            <br>&nbsp; Previous -
            <font color="#00FF00">L1 Button</font>		
            <br>&nbsp; Pause game -
            <font color="#00FF00">Start Button</font><br><br>
			&nbsp;</td>
	 </tr>
	</table>
