	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
          		<br><u><i><font color="#FFFF00">MISC CODES:</font></i></u><br>
			&nbsp; Hidden EX Option Mode -
                  &nbsp; <font color="#00FF00">At the main menu press Triangle, Triangle, Right, Circle, L1.</font>&nbsp;
			<br>&nbsp; Unlock Akuma -
                  &nbsp; <font color="#00FF00">Highlight any character in the top row and press Up</font>&nbsp;
			<br>&nbsp; Unlock Alpha Chun Li -
                  &nbsp; <font color="#00FF00">Highlight Chun Li and hold Select for five seconds, then press X</font>&nbsp;
			<br>&nbsp; Unlock Apocalypse -
                  &nbsp; <font color="#00FF00">Highlight Akuma, hold Select for five seconds and press R1</font>&nbsp;
			<br>&nbsp; Unlock Hyper Chun Li -
                  &nbsp; <font color="#00FF00">Highlight Chun Li, hold Select and press R1</font>&nbsp;
			<br>&nbsp; Original Costume Colors -
                  &nbsp; <font color="#00FF00">When selecting a character, press LP or LK</font>&nbsp;<br>
          		<br><u><i><font color="#FFFF00">ACTION REPLAY CODES:</font></i></u><br>
			&nbsp; Joker Command -
                  &nbsp; <font color="#00FF00"><br>D0042008 0000.</font>&nbsp;
			<br>&nbsp; Infinite Energy P1 -
                  &nbsp; <font color="#00FF00"><br>80042B6C 0090</font>&nbsp;
			<br>&nbsp; Level 3 Power Bar P1 -
                  &nbsp; <font color="#00FF00"><br>30042B70 0003</font>&nbsp;
			<br>&nbsp; Play As Apocalypse P1 -
                  &nbsp; <font color="#00FF00"><br>8004299C 0010</font>&nbsp;<br><br>
	 </tr>
	</table>
