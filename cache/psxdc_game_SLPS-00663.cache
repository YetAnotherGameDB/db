			<br>&nbsp;<u><i><font color="#FFFF00">BASIC CONTROLS:</font></i></u><br>
                  &nbsp; Move helicopter -
                  <font color="#00FF00">&nbsp;D-Pad</font>	  
                  <br>&nbsp; Forward (speed up) -
                  <font color="#00FF00">&nbsp;X Button</font>	
                  <br>&nbsp; Back (slow down) -
                  <font color="#00FF00">&nbsp;Circle Button</font>					  
                  <br>&nbsp; Fire machine gun  -
                  <font color="#00FF00">&nbsp;Square Button</font>					  
                  <br>&nbsp; Fire special weapon -
                  <font color="#00FF00">&nbsp;Triangle Button</font>				  
                  <br>&nbsp; Strafe left or right -
                  <font color="#00FF00">&nbsp;L1 or R1 Button</font>
                  <br>&nbsp; Change target lock -
                  <font color="#00FF00">&nbsp;R2 Button</font>
                  <br>&nbsp; Climb in altitude/take off -
                  <font color="#00FF00">&nbsp;L2 + D-Pad Down</font>
                  <br>&nbsp; Descend in altitude/land -
                  <font color="#00FF00">&nbsp;L2 + D-Pad Up</font>
                  <br>&nbsp; Change weapon -
                  <font color="#00FF00">&nbsp;Select + Triangle Button</font>
                  <br>&nbsp; Change view -
                  <font color="#00FF00">&nbsp;Select + X Button</font>
                  <br>&nbsp; Look left -
                  <font color="#00FF00">&nbsp;Select + L2 Button</font>
                  <br>&nbsp; Look right -
                  <font color="#00FF00">&nbsp;Select + R2 Button</font>				  
                  <br>&nbsp; Pause game -
                  <font color="#00FF00">&nbsp;Start Button</font><br><br>
				  &nbsp;</td>
	 </tr>
	</table>
