<!-- Game Cheats Sectional -->

<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">		
				  	<br><u><i><font color="#FFFF00">MISC CODES:</font></i></u><br>
			        &nbsp; Access All Levels -   
                  &nbsp; <font color="#00FF00">At the main title screen, hold Left + L2 and press Select</font>&nbsp;
				  	<br>&nbsp; Hidden Mini Game -   
                  &nbsp; <font color="#00FF00">At the Main Menu press Select + R2 on both controllers</font>&nbsp;
				  	<br>&nbsp; Enter the following codes while the game is paused:
				  	<br>&nbsp; Acquire Wingman -					
                  &nbsp; <font color="#00FF00">Select, L2, Select, R2, Square, Square, Square, Circle</font>&nbsp;
				  	<br>&nbsp; Cycle Gun Mode -					
                  &nbsp; <font color="#00FF00">Select, L2, Select, R2, Select, Select, Select</font>&nbsp;
				  	<br>&nbsp; Invincibility -					
                  &nbsp; <font color="#00FF00">Select, L2, Select, R2, Triangle, Triangle, Triangle, Square</font>&nbsp;
				  	<br>&nbsp; Max fuel and armor -					
                  &nbsp; <font color="#00FF00">Select, L2, Select, R2, Triangle, Triangle, Triangle, Circle</font>&nbsp;
				  	<br>&nbsp; Maximum Weapons -					
                  &nbsp; <font color="#00FF00">Select, L2, Select, R2, L1, L2, R1, R2</font>&nbsp;
				  	<br>&nbsp; No Collision Detection -					
                  &nbsp; <font color="#00FF00">Select, L2, Select, R2, Square, Square, Square, Square</font>&nbsp;
				  	<br>&nbsp; Skip Mission -					
                  &nbsp; <font color="#00FF00">Select, L2, Select, R2, Triangle, Triangle, Triangle, Down, Down, Down</font>&nbsp;
				  	<br>&nbsp; Upgrade Weapon -					
                  &nbsp; <font color="#00FF00">Select, L2, Select, R2, L1, L1, R1, R1</font>&nbsp;<br>
				  	<br><u><i><font color="#FFFF00">LEVEL PASSWORD CODES (Enter the following at the Password Screen):</font></i></u><br>
			        &nbsp; Black Out -   
                  &nbsp; <font color="#00FF00">1006</font>&nbsp;
				  	<br>&nbsp; Crack Down -   
                  &nbsp; <font color="#00FF00">0354</font>&nbsp;
				  	<br>&nbsp; Desert Fury -					
                  &nbsp; <font color="#00FF00">0203</font>&nbsp;
				  	<br>&nbsp; Ice Storm -					
                  &nbsp; <font color="#00FF00">1213</font>&nbsp;
				  	<br>&nbsp; Tiger Trap -					
                  &nbsp; <font color="#00FF00">0917</font>&nbsp;
				  	<br>&nbsp; Urban Shield -					
                  &nbsp; <font color="#00FF00">1018</font>&nbsp;<br><br>
