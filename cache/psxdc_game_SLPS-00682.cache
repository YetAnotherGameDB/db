<!-- Game Controls Table -->

<table class="tablestyle" id="table14a" cellspacing="4" cellpadding="0">
	<tr>
		<td class="sectional">

		
<!-- Game Controls Header -->
		
		<table class="headertable" id="table15" cellspacing="2" cellpadding="2">
			<tr>
				<td class="headercell">
				<img border="0" src="../../../images/headers/controls.jpg" width="240" height="33"></td>
			</tr>
		</table>

<!-- Game Controls Sectional -->

<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">MENUS CONTROLS:</font></i></u><br>
                  &nbsp; Move between actions:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Select item -
                  <font color="#00FF00">&nbsp;X Button</font>			
                  <br>&nbsp; Display help menu -
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Cancel selections and return to previous screen -
                  <font color="#00FF00">&nbsp;Select Button</font>				  
                  <br>&nbsp; Accept selections and continue to next screen -
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">GAMEPLAY CONTROLS:</font></i></u><br>
                  &nbsp; Activate manager menu:
                  <font color="#00FF00">&nbsp;L2 Button + R2 Button + D-Pad</font>
                  <br>&nbsp; Cycle between fielding/batting/pitching views -
                  <font color="#00FF00">&nbsp;Select Button</font>				  
                  <br>&nbsp; Pause / Display time-out menu -
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">ON THE MOUND - BEFORE THE PITCH CONTROLS:</font></i></u><br>
                  &nbsp; Move left/right on the rubber:
                  <font color="#00FF00">&nbsp;L1/R1 Buttons</font>
                  <br>&nbsp; Pick off base runner + select base -
                  <font color="#00FF00">&nbsp;Square Button + D-Pad</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">ON THE MOUND - PITCH SELECTION CONTROLS:</font></i></u><br>
                  &nbsp; Slow fastball:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Change-up -
                  <font color="#00FF00">&nbsp;X Button + D-Pad Up</font>				  
                  <br>&nbsp; Curve (screwball for lefty) -
                  <font color="#00FF00">&nbsp;X Button + D-Pad Right</font>
				  <br>&nbsp; Fastball -
                  <font color="#00FF00">&nbsp;X Button + D-Pad Down</font>
				  <br>&nbsp; Screball (curve for lefty) -
                  <font color="#00FF00">&nbsp;X Button + D-Pad Left</font>
				  <br>&nbsp; Slider -
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Sinker -
                  <font color="#00FF00">&nbsp;Circle Button + D-Pad Up</font>
                  <br>&nbsp; Pitchout -
                  <font color="#00FF00">&nbsp;Circle Button + D-Pad Right</font>
                  <br>&nbsp; Splitfinger -
                  <font color="#00FF00">&nbsp;Circle Button + D-Pad Down</font>
                  <br>&nbsp; Knuckleball -
                  <font color="#00FF00">&nbsp;Circle Button + D-Pad Left</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">IN THE FIELD - FIELDING THE BALL CONTROLS:</font></i></u><br>
                  &nbsp; Move toward ball at normal speed:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Jump up for the ball -
                  <font color="#00FF00">&nbsp;Square Button</font>				  
                  <br>&nbsp; Dive for ball -
                  <font color="#00FF00">&nbsp;Square Button + D-Pad</font>
				  <br>&nbsp; Switch to player nearest ball -
                  <font color="#00FF00">&nbsp;Triangle Button</font>
				  <br>&nbsp; Speed burst -
                  <font color="#00FF00">&nbsp;X Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">IN THE FIELD - THROWING THE BALL CONTROLS:</font></i></u><br>
                  &nbsp; Select base:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Conservative throw -
                  <font color="#00FF00">&nbsp;X Button</font>				  
                  <br>&nbsp; Aggressive throw -
                  <font color="#00FF00">&nbsp;Square Button</font>
				  <br>&nbsp; Switch to player with ball -
                  <font color="#00FF00">&nbsp;Triangle Button</font>
				  <br>&nbsp; Run with ball -
                  <font color="#00FF00">&nbsp;Circle Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">AT THE PLATE - BEFORE THE PITCH CONTROLS:</font></i></u><br>
                  &nbsp; Position batter in the batter's box:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Select stance -
                  <font color="#00FF00">&nbsp;L1 or R1 Button</font>				  
                  <br>&nbsp; Warm up swing -
                  <font color="#00FF00">&nbsp;Square or X Button</font>
				  <br>&nbsp; Switch to baserunner -
                  <font color="#00FF00">&nbsp;Triangle Button</font>
				  <br>&nbsp; View baserunners -
                  <font color="#00FF00">&nbsp;L2 + R2 Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">AT THE PLATE - HITTING THE BALL CONTROLS:</font></i></u><br>
                  &nbsp; Normal swing (hold to swing, release quickly to check swing):
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Aggressive power swing -
                  <font color="#00FF00">&nbsp;Square Button</font>				  
                  <br>&nbsp; Bunt (hold to bunt, release quickly to check swing) -
                  <font color="#00FF00">&nbsp;Circle Button</font>
				  <br>&nbsp; Hit fly ball -
                  <font color="#00FF00">&nbsp;D-Pad Up</font>
				  <br>&nbsp; Hit to lect field -
                  <font color="#00FF00">&nbsp;D-Pad Left</font>
				  <br>&nbsp; Hit grounder -
                  <font color="#00FF00">&nbsp;D-Pad Down</font>
				  <br>&nbsp; Hit to right field -
                  <font color="#00FF00">&nbsp;D-Pad Right</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">ON THE BASEPATHS - BEFORE THE PITCH CONTROLS:</font></i></u><br>
                  &nbsp; Switch control to runner on first, second, third, then back to batter:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Increase lead-off for runners on base -
                  <font color="#00FF00">&nbsp;L2 Button + D-Pad</font>				  
                  <br>&nbsp; Run forward to the next base -
                  <font color="#00FF00">&nbsp;D-Pad Up</font>
				  <br>&nbsp; Run back to previous base -
                  <font color="#00FF00">&nbsp;D-Pad Down</font>
				  <br>&nbsp; Decrease lead-off for runner on base, or return runners on a hit -
                  <font color="#00FF00">&nbsp;R2 Button + D-Pad</font>
				  <br>&nbsp; Advance all runners -
                  <font color="#00FF00">&nbsp;L1 + L2 Button</font>
				  <br>&nbsp; Return all runners -
                  <font color="#00FF00">&nbsp;R1 + R2 Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">ON THE BASEPATHS - AFTER THE PITCH CONTROLS:</font></i></u><br>
                  &nbsp; Switch control to runner on first, second, third, and back to batter:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Advance runners on a hit -
                  <font color="#00FF00">&nbsp;L2 Button + D-Pad</font>				  
                  <br>&nbsp; Return runners on a hit -
                  <font color="#00FF00">&nbsp;R2 Button + D-Pad </font>
				  <br>&nbsp; Head-first slide -
                  <font color="#00FF00">&nbsp;Square Button</font>
				  <br>&nbsp; Feet-first slide -
                  <font color="#00FF00">&nbsp;Circle Button</font>
				  <br>&nbsp; Speed burst -
                  <font color="#00FF00">&nbsp;X Button</font>
				  <br>&nbsp; Advance/return all runners -
                  <font color="#00FF00">&nbsp;L2/R1 Buttons</font><br><br>
				  &nbsp;</td>
	 </tr>
	</table>
       	</td>
     </tr>
</table>

      
