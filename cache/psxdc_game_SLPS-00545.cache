            <td class="darkcell" style="width: 130px; height: 105px; text-align: center">
		<a target="_blank" href="../../../images/covers/J/S/SLPS-00545/SLPS-00545-F-ALL.html">
		<img border="0" src="../../../images/thumbs/J/S/SLPS-00545/SLPS-00545-F-ALL.jpg" width="100" height="100"></a></td>
            <td class="darkcell" style="width: 130px; height: 105px; text-align: center">
		<a target="_blank" href="../../../images/covers/J/S/SLPS-00545/SLPS-00545-B-ALL.html">
		<img border="0" src="../../../images/thumbs/J/S/SLPS-00545/SLPS-00545-B-ALL.jpg" width="100" height="100"></a></td>
