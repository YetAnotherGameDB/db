<!-- Game Controls Sectional -->

<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">FIELD SCREEN / TOWN MAP SCREEN CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick</font>
                  <br>&nbsp; Talk, inspect:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Enables character to run when pressed at the same time as the directional button or left stick:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Display menu screen:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Display menu screen:
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">RING COMMAND SCREEN CONTROLS:</font></i></u><br>
                  &nbsp; Switch ring commands:
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick</font>
                  <br>&nbsp; Execute:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Cancel:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Switch ring commands:
                  <font color="#00FF00">&nbsp;R1/L1 Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">MENU SCREEN CONTROLS:</font></i></u><br>
                  &nbsp; Cursor movement:
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick</font>
                  <br>&nbsp; Execute:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Cancel:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Skip to the next screen:
                  <font color="#00FF00">&nbsp;R1 Button</font>
                  <br>&nbsp; Previous to the next screen:
                  <font color="#00FF00">&nbsp;L1 Button</font>
                  <br>&nbsp; Return to field screen:
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">WORLD MAP SCREEN CONTROLS:</font></i></u><br>
                  &nbsp; Cursor movement:
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick</font>
                  <br>&nbsp; Execute:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Cancel:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Artifact selection:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Display mana level:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Display help screen:
                  <font color="#00FF00">&nbsp;Select Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">BATTLE SCREEN CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick</font>
                  <br>&nbsp; Quick attack:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Ability:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Power attack:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Ability:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Special technique or magic:
                  <font color="#00FF00">&nbsp;R1/R2/L1/L2 Button</font>
                  <br>&nbsp; Pause game:
                  <font color="#00FF00">&nbsp;Start Button</font><br><br>
        &nbsp;</td>
	 </tr>
	</table>
       	</td>
     </tr>
</table>

      
