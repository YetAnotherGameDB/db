<!-- Game Controls Sectional -->

<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">BASIC CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Bare-fisted attack:
                  <font color="#00FF00">&nbsp;X, Circle or Square Button (with no weapon)</font>
                  <br>&nbsp; Light slash attack:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Medium slash attack:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Strong slash attack:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Light and medium slash attack:
                  <font color="#00FF00">&nbsp;R1 Button</font>
                  <br>&nbsp; Medium and strong slash attack:
                  <font color="#00FF00">&nbsp;R2 Button</font>
                  <br>&nbsp; Light and medium and strong slash attack:
                  <font color="#00FF00">&nbsp;L1 Button</font>
                  <br>&nbsp; Light and medium and strong slash attack plus a kick:
                  <font color="#00FF00">&nbsp;L2 Button</font>
                  <br>&nbsp; Kick attack:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Below-the-belt boot:
                  <font color="#00FF00">&nbsp;D-Pad Right + Triangle Button</font>
                  <br>&nbsp; Off-balance swipe:
                  <font color="#00FF00">&nbsp;D-Pad Down Right + Triangle Button</font>
                  <br>&nbsp; Jaw-smasher stomp:
                  <font color="#00FF00">&nbsp;D-Pad Left + Triangle Button</font>
                  <br>&nbsp; Mid-section mash:
                  <font color="#00FF00">&nbsp;D-Pad Down Left + Triangle Button</font>
                  <br>&nbsp; Increase power:
                  <font color="#00FF00">&nbsp;X + Circle + Square Button</font>
                  <br>&nbsp; Torso attack:
                  <font color="#00FF00">&nbsp;D-Pad Right + Circle + Square Button</font>
                  <br>&nbsp; Pause game:
                  <font color="#00FF00">&nbsp;Start Button</font><br>
     &nbsp;</td>
	 </tr>
	</table>
