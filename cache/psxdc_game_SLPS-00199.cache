<!-- Game Cheats Sectional -->

<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
				  <br><u><i><font color="#FFFF00">MISC CODES:</font></i></u><br>
			        &nbsp; Infinite Fire -
                  &nbsp; <font color="#00FF00">At the Tonight's Matchup screen press Down, Right, Right, Circle, Triangle, Right</font>&nbsp;
			        <br>&nbsp; Max Power -
                  &nbsp; <font color="#00FF00">At the Tonight's Matchup screen press Right, Right, Left, Right, X, X, Right</font>&nbsp;
				  
			        <br>&nbsp; Quick Hands -
                  &nbsp; <font color="#00FF00">At the Tonight's Matchup screen press Left, Left, Left, Left, Circle, Right</font>&nbsp;
			        <br>&nbsp; Rainbow Shots -
                  &nbsp; <font color="#00FF00">At the Tonight's Matchup screen press Up, Down, Down, Right, Up, Circle, Circle, Cicle, Circle, Down</font>&nbsp;
			        <br>&nbsp; Show Shot Percentage -
                  &nbsp; <font color="#00FF00">At the Tonight's Matchup screen press Up, Up, Down, Down, Triangle</font>&nbsp;
			        <br>&nbsp; Super Dunks -
                  &nbsp; <font color="#00FF00">At the Tonight's Matchup screen press Left, Right, X, Circle, Circle, X</font>&nbsp;
			        <br>&nbsp; Teleport Dunks -
                  &nbsp; <font color="#00FF00">At the Tonight's Matchup screen press up, Right, Right, Left, Circle, Down, Left, Left, Circle, Square</font>&nbsp;
			        <br><br>&nbsp; Select your team and when Tonight's Match-Up appears, enter any of the following codes before Loading Game appears. You should see the mode on before the tipoff if it was entered correctly. Press and repeat at least 5 times:
			        <br>&nbsp; Baby Mode -					
                  &nbsp; <font color="#00FF00">Square, Circle</font>&nbsp;
			        <br>&nbsp; Big Head Mode -					
                  &nbsp; <font color="#00FF00">Square, X, Circle, Triangle</font>&nbsp;
			        <br>&nbsp; Huge Mode -					
                  &nbsp; <font color="#00FF00">Triangle, X</font>&nbsp;
			        <br>&nbsp; Mammoth Head -					
                  &nbsp; <font color="#00FF00">Square, Triangle, Circle, X</font>&nbsp;<br><br>
				  </tr>
	</table>
