<!-- Game Controls Sectional -->

<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">BASIC CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Kick:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Strike / Take item:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Block:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Jump up:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Dodge left or right:
                  <font color="#00FF00">&nbsp;L1 or R1 Button</font>
                  <br>&nbsp; Use inventory item:
                  <font color="#00FF00">&nbsp;R2 Button</font>
                  <br>&nbsp; Sidestep left or right:
                  <font color="#00FF00">&nbsp;L1 or R1 + Circle Button</font>
                  <br>&nbsp; Walk backward:
                  <font color="#00FF00">&nbsp;Circle Button + D-Pad down</font>
                  <br>&nbsp; Rotate inventory clockwise:
                  <font color="#00FF00">&nbsp;L2 + D-Pad Left</font>
                  <br>&nbsp; Rotate inventory counter-clockwise:
                  <font color="#00FF00">&nbsp;L2 + D-Pad Right</font>
                  <br>&nbsp; Lives remaining / Map view:
                  <font color="#00FF00">&nbsp;Select Button</font>
                  <br>&nbsp; Pause game / Menu:
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">IGNATIUS COMBINATIONS CONTROLS:</font></i></u><br>
                  &nbsp; Hammer Curl:
                  <font color="#00FF00">&nbsp;X, Square, Square</font>
                  <br>&nbsp; Windmill Slam:
                  <font color="#00FF00">&nbsp;X, X, X, Square</font>
                  <br>&nbsp; Scottish Backhand:
                  <font color="#00FF00">&nbsp;Square, X, Square</font>
                  <br>&nbsp; Hammerhead Crush:
                  <font color="#00FF00">&nbsp;X, Square, Triangle</font>
                  <br>&nbsp; Roundhouse Volley:
                  <font color="#00FF00">&nbsp;D-Pad Up + Square</font>
                  <br>&nbsp; Flying Elbow Smash:
                  <font color="#00FF00">&nbsp;Triangle, X</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">NADIA F. COMBINATIONS CONTROLS:</font></i></u><br>
                  &nbsp; Side Flip Kick:
                  <font color="#00FF00">&nbsp;Square, Square, Triangle, X</font>
                  <br>&nbsp; Feet of Fury:
                  <font color="#00FF00">&nbsp;Square, X, X, X</font>
                  <br>&nbsp; Cyclone Volley:
                  <font color="#00FF00">&nbsp;X, X, X, Square</font>
                  <br>&nbsp; Back Flip Kick Combo:
                  <font color="#00FF00">&nbsp;Square, Square, Square, X, D-Pad Up + X</font>
                  <br>&nbsp; Bloody Ballerina:
                  <font color="#00FF00">&nbsp;X, Square, D-Pad Up + Square + X</font>
                  <br>&nbsp; Flying Cross:
                  <font color="#00FF00">&nbsp;Triangle, Square</font><br>
     &nbsp;</td>
	 </tr>
	</table>
       	</td>
     </tr>
</table>

      
