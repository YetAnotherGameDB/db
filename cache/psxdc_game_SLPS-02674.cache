<!-- Game Controls Table -->

<table class="tablestyle" id="table14a" cellspacing="4" cellpadding="0">
	<tr>
		<td class="sectional">

		
<!-- Game Controls Header -->
		
		<table class="headertable" id="table15" cellspacing="2" cellpadding="2">
			<tr>
				<td class="headercell">
				<img border="0" src="../../../images/headers/controls.jpg" width="240" height="33"></td>
			</tr>
		</table>

<!-- Game Controls Sectional -->

<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">GETTING THERE AND CASTING CONTROLS:</font></i></u><br>
                  &nbsp; Drive boat -
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick</font>
                  <br>&nbsp; Stop boat and prepare to cast -
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Return to driving boat -
                  <font color="#00FF00">&nbsp;Triangle Button</font>><br>
			<br>&nbsp;<u><i><font color="#FFFF00">CASTING CONTROLS:</font></i></u><br>
                  &nbsp; Relocate your casting cursor -
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick</font>
                  <br>&nbsp; Start casting meter / Cast -
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Choose tackle outfit -
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Underwater camera (while driving or before casting) -
                  <font color="#00FF00">&nbsp;R2 Button</font>				  
                  <br>&nbsp; Toggle map, time, temprature and wind indicators on/off -
                  <font color="#00FF00">&nbsp;L2 Button</font>
                  <br>&nbsp; Use trolling motor (while on the bow of the boat) -
                  <font color="#00FF00">&nbsp;L1 Button + D-Pad</font>
                  <br>&nbsp; Access select menu -
                  <font color="#00FF00">&nbsp;Select Button</font>				  
                  <br>&nbsp; Pause game -
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">REELING CONTROLS:</font></i></u><br>
                  &nbsp; Move rod -
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick</font>
                  <br>&nbsp; Reel in the line -
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Spool free lets the line unreel with the weight of the fish or lure -
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Set hook (when you feel the strike) -
                  <font color="#00FF00">&nbsp;Triangle Button</font>				  
                  <br>&nbsp; Retrieve your lure instantly (when fish aren't biting) -
                  <font color="#00FF00">&nbsp;X + Circle Button</font>				  
                  <br>&nbsp; Drag control set it low to allow a fighting fist to take out the line without breaking it or set it high when you want to put pressure on the fish not to shake off the hook -
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Twitch lure -
                  <font color="#00FF00">&nbsp;L1 or L2 Button</font>
                  <br>&nbsp; Access select menu -
                  <font color="#00FF00">&nbsp;Select Button</font>				  
                  <br>&nbsp; Pause game -
                  <font color="#00FF00">&nbsp;Start Button</font><br><br>	
				  &nbsp;</td>
	 </tr>
	</table>
       	</td>
     </tr>
</table>

      
