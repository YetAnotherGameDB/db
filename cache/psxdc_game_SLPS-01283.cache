<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">BOX MINI GAME / AVOID BOMB MINI GAME CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Jump:
                  <font color="#00FF00">&nbsp;Circle Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">SHOOT THE WEASEL CONTROLS:</font></i></u><br>
                  &nbsp; Shoot left image:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Shoot center image:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Shoot right image:
                  <font color="#00FF00">&nbsp;Circle Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">ANSWER THE PHONE CONTROLS:</font></i></u><br>
                  &nbsp; Answer:
                  <font color="#00FF00">&nbsp;Push the different combination of D-Pad & X, Square, Triangle & Circle Buttons</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">PENGUIN DART CONTROLS:</font></i></u><br>
                  &nbsp; Angles:
                  <font color="#00FF00">&nbsp;Circle Buttons</font>
                  <br>&nbsp; Move penguin left or right:
                  <font color="#00FF00">&nbsp;D-Pad left or right</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">FLAG MINI GAME CONTROLS:</font></i></u><br>
                  &nbsp; Rise red flag:
                  <font color="#00FF00">&nbsp;D-pad right</font>
                  <br>&nbsp; Rise white flag:
                  <font color="#00FF00">&nbsp;D-pad left</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">CLIMB BUILDING CONTROLS:</font></i></u><br>
                  &nbsp; Climb:
                  <font color="#00FF00">&nbsp;X + Circle Buttons</font>
                  <br>&nbsp; Dodge:
                  <font color="#00FF00">&nbsp;D-Pad left</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">WHACK-A-HOLE MINI GAME CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Hit:
                  <font color="#00FF00">&nbsp;Circle Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">CATCH POPCORNS MINI GAME CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Jump:
                  <font color="#00FF00">&nbsp;Circle Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">KARATE MINI GAME CONTROLS:</font></i></u><br>
                  &nbsp; Select strength:
                  <font color="#00FF00">&nbsp;Circle Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">ADD & COPY MOVEMENTS MINI GAME CONTROLS:</font></i></u><br>
                  &nbsp; Movements:
                  <font color="#00FF00">&nbsp;D-Pad + X & Circle Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">MATCH PAIR OF ANIMAL SOUNDS MINI GAME CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Jump / Select:
                  <font color="#00FF00">&nbsp;Circle Button</font><br><br>
        &nbsp;</td>
	 </tr>
