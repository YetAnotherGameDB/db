<table class="tablestyle" id="table14a" cellspacing="4" cellpadding="0">
	<tr>
		<td class="sectional">

		
<!-- Game Controls Header -->
		
		<table class="headertable" id="table15" cellspacing="2" cellpadding="2">
			<tr>
				<td class="headercell">
				<img border="0" src="../../../images/headers/controls.jpg" width="240" height="33"></td>
			</tr>
		</table>

<!-- Game Controls Sectional -->

<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">MOVING CONTROLS:</font></i></u><br>
                  &nbsp; Advance / Run forwards:
                  <font color="#00FF00">&nbsp;D-Pad Up</font>
                  <br>&nbsp; Turn right:
                  <font color="#00FF00">&nbsp;D-Pad Right</font>
                  <br>&nbsp; Turn left:
                  <font color="#00FF00">&nbsp;D-Pad Left</font>
                  <br>&nbsp; Retreat / Walk backwards:
                  <font color="#00FF00">&nbsp;D-Pad Down</font>
                  <br>&nbsp; Quick left turn:
                  <font color="#00FF00">&nbsp;D-Pad Left + Down</font>
                  <br>&nbsp; Quick right turn:
                  <font color="#00FF00">&nbsp;D-Pad Right + Down</font>
                  <br>&nbsp; Step in / quick step forward:
                  <font color="#00FF00">&nbsp;D-Pad Up (twice)</font>
                  <br>&nbsp; Step out / quick step backwards:
                  <font color="#00FF00">&nbsp;D-Pad Down (twice)</font>
                  <br>&nbsp; Left step:
                  <font color="#00FF00">&nbsp;D-Pad Left (twice)</font>
                  <br>&nbsp; Right step:
                  <font color="#00FF00">&nbsp;D-Pad Right (Twice)</font><br>
                  <br>&nbsp;<u><i><font color="#FFFF00">JUMPING CONTROLS:</font></i></u><br>
                  &nbsp; Jump straight up:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Forward jump:
                  <font color="#00FF00">&nbsp;X Button + D-Pad Up</font>
                  <br>&nbsp; Jump backwards:
                  <font color="#00FF00">&nbsp;D-Pad Down + X Button (twice)</font>
                  <br>&nbsp; Jump left or right:
                  <font color="#00FF00">&nbsp;X Button + D-Pad left or right</font>
                  <br>&nbsp; Quick reverse, jumps up and turns 180 degrees:
                  <font color="#00FF00">&nbsp;Circle Button + X Button or R1 Button + X Button</font>
                  <br>&nbsp; Strong forward jump:
                  <font color="#00FF00">&nbsp;D-Pad Up (twice) + X Button</font>
                  <br>&nbsp; Moonsault:
                  <font color="#00FF00">&nbsp;D-Pad Down + Up + X Button</font>
                  <br>&nbsp; Ricochet jump, kick off wall:
                  <font color="#00FF00">&nbsp;X Button (close to a wall)</font><br>
                  <br>&nbsp;<u><i><font color="#FFFF00">STEALTH MODE (CROUCHING) CONTROLS:</font></i></u><br>
                  &nbsp; Crouch:
                  <font color="#00FF00">&nbsp;Circle Button or R1 Button</font>
                  <br>&nbsp; Advance while crouching:
                  <font color="#00FF00">&nbsp;Circle Button or R1 Button + D-Pad Up</font>
                  <br>&nbsp; Retreat while crouching:
                  <font color="#00FF00">&nbsp;Circle Button or R1 Button + D-Pad Down</font>
                  <br>&nbsp; Move left or right while crouching:
                  <font color="#00FF00">&nbsp;Circle Button or R1 Button + D-Pad left or right</font>
                  <br>&nbsp; Turn right or left while crouching:
                  <font color="#00FF00">&nbsp;Circle Button or R1 Button + D-Pad Right or left + Down</font><br>
                  <br>&nbsp;<u><i><font color="#FFFF00">STEALTH MODE (WALLS) CONTROLS:</font></i></u><br>
                  &nbsp; Press back against a wall:
                  <font color="#00FF00">&nbsp;Circle Button or R1 Button (close to a wall)</font>
                  <br>&nbsp; Move forward or backward while pressing against a wall:
                  <font color="#00FF00">&nbsp;Circle Button or R1 Button (close to a wall) + D-Pad Up or Down</font>
                  <br>&nbsp; Move left or right while pressing against a wall:
                  <font color="#00FF00">&nbsp;Circle Button or R1 Button (close to a wall) + D-Pad left or right</font><br>
                  <br>&nbsp;<u><i><font color="#FFFF00">STEALTH MODE (ROLLING) CONTROLS:</font></i></u><br>
                  &nbsp; Roll forward or backwards:
                  <font color="#00FF00">&nbsp;Circle Button or R1 Button + D-Pad Up or down (twice)</font>
                  <br>&nbsp; Roll to the right or left:
                  <font color="#00FF00">&nbsp;Circle Button or R1 Button + D-Pad Right or left (twice)</font><br>
                  <br>&nbsp;<u><i><font color="#FFFF00">BLOCKING CONTROLS:</font></i></u><br>
                  &nbsp; Blocks enemy attacks from the front:
                  <font color="#00FF00">&nbsp;Down Button (while enemy strikes)</font>
                  <br>&nbsp; Knock arrow out of the air:
                  <font color="#00FF00">&nbsp;Square Button (when arrow is in range)</font><br>
                  <br>&nbsp;<u><i><font color="#FFFF00">ATTACK CONTROLS:</font></i></u><br>
                  &nbsp; Forward slash:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Slash while jumping:
                  <font color="#00FF00">&nbsp;Square Button (while jumping)</font>
                  <br>&nbsp; Slash while crouching:
                  <font color="#00FF00">&nbsp;Circle Button + Square Button</font>
                  <br>&nbsp; Double right slashes:
                  <font color="#00FF00">&nbsp;D-Pad Right or Left + Square (twice)</font>
                  <br>&nbsp; Slash while running forward:
                  <font color="#00FF00">&nbsp;D-Pad Up (twice) + Square Button</font>
                  <br>&nbsp; Roll 180 degrees and slash:
                  <font color="#00FF00">&nbsp;D-Pad Down or Up + Square Button</font>
                  <br>&nbsp; Left or right switchback slash:
                  <font color="#00FF00">&nbsp;D-Pad Left or Right + Square Button, D-Pad Left + Square Button</font><br>
                  <br>&nbsp;<u><i><font color="#FFFF00">ITEMS CONTROLS:</font></i></u><br>
                  &nbsp; Walk up close to any item and pick it up:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Aim shuriken:
                  <font color="#00FF00">&nbsp;Triangle Button (hold) + D-Pad</font>
                  <br>&nbsp; Throw shuriken:
                  <font color="#00FF00">&nbsp;Triangle Button (release)</font>
                  <br>&nbsp; Aim grappling rope:
                  <font color="#00FF00">&nbsp;Triangle Button (hold) + D-Pad</font>
                  <br>&nbsp; Throw grappling rope:
                  <font color="#00FF00">&nbsp;Triangle Button (release)</font>
                  <br>&nbsp; Select item:
                  <font color="#00FF00">&nbsp;L2 Button or R2 Button</font>
                  <br>&nbsp; See map:
                  <font color="#00FF00">&nbsp;Select Button</font><br>
                  <br>&nbsp;<u><i><font color="#FFFF00">OTHER CONTROLS:</font></i></u><br>
                  &nbsp; Look around:
                  <font color="#00FF00">&nbsp;L1 Button + D-Pad</font>
                  <br>&nbsp; Quick reset to title screen:
                  <font color="#00FF00">&nbsp;Select Button + Start Button</font>
                  <br>&nbsp; Pause game:
                  <font color="#00FF00">&nbsp;Start Button</font><br><br>
			&nbsp;</td>
	 </tr>
	</table>
       	</td>
     </tr>
</table>

      
