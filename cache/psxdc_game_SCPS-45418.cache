	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">ADVENTURE PART CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Select action:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Pause game:
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">ROBOT PART CONTROLS:</font></i></u><br>
                  &nbsp; Step forward left foot:
                  <font color="#00FF00">&nbsp;L1 Button</font>
                  <br>&nbsp; Step Forward Right foot:
                  <font color="#00FF00">&nbsp;R1 Button</font>
                  <br>&nbsp; Step Backward Left foot:
                  <font color="#00FF00">&nbsp;L2 Button</font>
                  <br>&nbsp; Step Backward Right foot:
                  <font color="#00FF00">&nbsp;R2 Button</font>
                  <br>&nbsp; Turn left:
                  <font color="#00FF00">&nbsp;L1 + L2 Button</font>
                  <br>&nbsp; Turn right:
                  <font color="#00FF00">&nbsp;R1 + R2 Button</font>
                  <br>&nbsp; Move upper torse:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Left Punch:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Right Punch:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Block:
                  <font color="#00FF00">&nbsp;L1 + L2 + R1 + R2 Button</font>
                  <br>&nbsp; Crouch:
                  <font color="#00FF00">&nbsp;L2 + R2 Button</font>
                  <br>&nbsp; Jump:
                  <font color="#00FF00">&nbsp;While Crouching hit L1 + R1 Button</font>
                  <br>&nbsp; Pick up objects:
                  <font color="#00FF00">&nbsp;While crouching +Circle or Square Button</font>
                  <br>&nbsp; Safely Drop object:
                  <font color="#00FF00">&nbsp;L2 + R2 Button</font>
                  <br>&nbsp; Destroy object:
                  <font color="#00FF00">&nbsp;Square or Circle Button</font>
                  <br>&nbsp; Special Pose:
                  <font color="#00FF00">&nbsp;L1 + R1 Button</font>
                  <br>&nbsp; Change between character and robot:
                  <font color="#00FF00">&nbsp;Select Button</font><br><br>
     &nbsp;</td>
	 </tr>
	</table>
