<!-- Game Controls Sectional -->

<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">BASIC CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick</font>
                  <br>&nbsp; Kick:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Dodge:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Slash weak:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Slash strong:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Dash:
                  <font color="#00FF00">&nbsp;D-Pad right (twice)</font>
                  <br>&nbsp; Basic throw or push:
                  <font color="#00FF00">&nbsp;Square + X Button</font>
                  <br>&nbsp; Basic throw or pull:
                  <font color="#00FF00">&nbsp;D-Pad Left + Square + X Button</font>
                  <br>&nbsp; Back of sword attack:
                  <font color="#00FF00">&nbsp;Square + Triangle Button</font>
                  <br>&nbsp; Strategic dodge:
                  <font color="#00FF00">&nbsp;D-Pad Right (just before a hit or attack)</font>
                  <br>&nbsp; Crossed sword crunch:
                  <font color="#00FF00">&nbsp;Square, Triangle, X or Circle Buttons (tap continuously)</font>
                  <br>&nbsp; Power defense:
                  <font color="#00FF00">&nbsp;D-Pad Left (just before a hit or attack)</font>
                  <br>&nbsp; Ground attack:
                  <font color="#00FF00">&nbsp;D-Pad Down + Square + Triangle or X Button (while opponent is down)</font>
                  <br>&nbsp; Roll forward:
                  <font color="#00FF00">&nbsp;D-Pad Right (while down)</font>
                  <br>&nbsp; Roll backward:
                  <font color="#00FF00">&nbsp;D-Pad Left (while down)</font>
                  <br>&nbsp; Pick up weapon:
                  <font color="#00FF00">&nbsp;Square or Triangle Button</font>
                  <br>&nbsp; Menu:
                  <font color="#00FF00">&nbsp;Start Button</font><br><br>
     &nbsp;</td>
	 </tr>
	</table>
