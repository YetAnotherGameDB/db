<!-- Game Controls Sectional -->

<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">FIGHTER MODE CONTROLS:</font></i></u><br>
                  &nbsp; Move ship:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Missiles:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; DSS (Dynamic Situation System):
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Chaff:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Gunpod or Beam depending on the Fighter:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; View (Check where your enemy is):
                  <font color="#00FF00">&nbsp;L1 Button</font>
                  <br>&nbsp; Search (Automatically moves your Fighter until it locks your
enemy). Uses Turbo Power:
                  <font color="#00FF00">&nbsp;L2 Button</font>
                  <br>&nbsp; Brake:
                  <font color="#00FF00">&nbsp;R1 Button</font>
                  <br>&nbsp; Super Brake (It looks like in Guardian or GERWALK
Phase). Uses Turbo Power (quite a bit!).:
                  <font color="#00FF00">&nbsp;R1 Button (twice)</font>
                  <br>&nbsp; Uses Turbo Power:
                  <font color="#00FF00">&nbsp;R2 Button</font>
                  <br>&nbsp; Super Turbo. Uses twice as much Turbo Power thn
normal Turbo:
                  <font color="#00FF00">&nbsp;R2 Button (twice)</font>
                  <br>&nbsp; Pause game:
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">BATTOROID MODE (TYPE A) CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Missiles:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; DSS (Dynamic Situation System):
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Guard and while in the air it will make you go down faster:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Gunpod or Cannon depending on the Battroid:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Turn left or right:
                  <font color="#00FF00">&nbsp;L1 or R1 Button</font>
                  <br>&nbsp; Search (Automatically moves your Battroid until it locks your
enemy). Uses Turbo Power:
                  <font color="#00FF00">&nbsp;L2 Button</font>
                  <br>&nbsp; Turbo. Hold it without pressing in any direction and you will fly.
Uses Turbo Power:
                  <font color="#00FF00">&nbsp;R2 Button</font>
                  <br>&nbsp; Fly:
                  <font color="#00FF00">&nbsp;R2 Button (twice & hold it)</font>
                  <br>&nbsp; Pause game:
                  <font color="#00FF00">&nbsp;Start Button</font><br>
        &nbsp;</td>
	 </tr>
	</table>
       	</td>
     </tr>
</table>

      
