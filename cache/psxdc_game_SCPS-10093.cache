<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">ON NORMAL COURSE CONTROLS:</font></i></u><br>
                  &nbsp; Change shot direction:
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick Left/Right</font>
                  <br>&nbsp; Change camera viewpoint up/down:
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick Up/Down</font>
                  <br>&nbsp; Hit the ball:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Change camera viewpoint (retreat):
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Change shot mode:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Change camera viewpoint (advance):
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Select the club:
                  <font color="#00FF00">&nbsp;L1 or R1 Button</font>
                  <br>&nbsp; Return the viewpoint, scatter grass:
                  <font color="#00FF00">&nbsp;R2 Button</font>
                  <br>&nbsp; View score card/adjust training settings:
                  <font color="#00FF00">&nbsp;Select Button</font>
                  <br>&nbsp; Display entire hole:
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">ON GREEN CONTROLS:</font></i></u><br>
                  &nbsp; Change putting direction:
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick Left/Right</font>
                  <br>&nbsp; Change camera viewpoint up/down:
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick Up/Down</font>
                  <br>&nbsp; Putt:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Change camera viewpoint (retreat):
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Change putting mode:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Change camera viewpoint (advance):
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; View from other side:
                  <font color="#00FF00">&nbsp;L1 Button</font>
                  <br>&nbsp; Display cross section:
                  <font color="#00FF00">&nbsp;L2 Button</font>
                  <br>&nbsp; Return the viewpoint:
                  <font color="#00FF00">&nbsp;R2 Button</font>
                  <br>&nbsp; View score card:
                  <font color="#00FF00">&nbsp;Select Button</font>
                  <br>&nbsp; Display entire green:
                  <font color="#00FF00">&nbsp;Start Button</font><br><br>
        &nbsp;</td>
	 </tr>
	</table>
