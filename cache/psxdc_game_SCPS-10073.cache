<!-- Game Controls Sectional -->

<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">BASIC CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad or Analog Stick</font>
                  <br>&nbsp; Jump:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Slide (while running):
                  <font color="#00FF00">&nbsp;Circle or R1 Button (Hold) + D-Pad or Left Analog Stick</font>
                  <br>&nbsp; Super slide high jump:
                  <font color="#00FF00">&nbsp;Circle or R1 Button + X Button + D-Pad or Left Analog Stick</font>
                  <br>&nbsp; Spin attack:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Crouch / Duck (while standing):
                  <font color="#00FF00">&nbsp;Circle or R1 Button</font>
                  <br>&nbsp; Show status panel:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Body slam:
                  <font color="#00FF00">&nbsp;X + Circle Button</font>
                  <br>&nbsp; High jump:
                  <font color="#00FF00">&nbsp;Circle + X Button</font>
                  <br>&nbsp; Crawl in specified direction:
                  <font color="#00FF00">&nbsp;Circle Button + D-Pad</font>
                  <br>&nbsp; Pause game:
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">HANGING CONTROLS:</font></i></u><br>
                  &nbsp; Pull legs up:
                  <font color="#00FF00">&nbsp;Circle or R1 Button</font>
                  <br>&nbsp; Release from hang:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Spin:
                  <font color="#00FF00">&nbsp;Square Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">SWIMMING CONTROLS:</font></i></u><br>
                  &nbsp; Swim and spin forward:
                  <font color="#00FF00">&nbsp;Circle, Square or R1 Button</font>
                  <br>&nbsp; Fast kick:
                  <font color="#00FF00">&nbsp;X Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">JET SUB CONTROLS:</font></i></u><br>
                  &nbsp; Turbo burst:
                  <font color="#00FF00">&nbsp;Circle or R1 Button</font>
                  <br>&nbsp; Torpedo:
                  <font color="#00FF00">&nbsp;Square Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">MOTORCYCLE CONTROLS:</font></i></u><br>
                  &nbsp; Brake:
                  <font color="#00FF00">&nbsp;Circle, Square or R1 Button</font>
                  <br>&nbsp; Accelerate:
                  <font color="#00FF00">&nbsp;X Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">BI-PLANE CONTROLS:</font></i></u><br>
                  &nbsp; Machine gun:
                  <font color="#00FF00">&nbsp;Circle or R1 Button</font>
                  <br>&nbsp; Barrel roll:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Air brakes:
                  <font color="#00FF00">&nbsp;X Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">JET SKI CONTROLS:</font></i></u><br>
                  &nbsp; Flip:
                  <font color="#00FF00">&nbsp;X + D-Pad or Left Analog Stick</font>
                  <br>&nbsp; Hard turn:
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick Down Right or Down Left</font>
                  <br>&nbsp; Accelerate:
                  <font color="#00FF00">&nbsp;X Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">PURA THE TIGER & T-REX RIDING CONTROLS:</font></i></u><br>
                  &nbsp; Jump:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Pura the tiger fast run:
                  <font color="#00FF00">&nbsp;Circle, Square, or R1 Button</font>
                  <br>&nbsp; Jump off t-rex:
                  <font color="#00FF00">&nbsp;Circle or R1 Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">SPECIAL POWER MOVES CONTROLS:</font></i></u><br>
                  &nbsp; Super body slam:
                  <font color="#00FF00">&nbsp;X + Circle Button</font>
                  <br>&nbsp; Super double jump:
                  <font color="#00FF00">&nbsp;X + X Button</font>
                  <br>&nbsp; Crash dash:
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick + R2 Button</font>
                  <br>&nbsp; Bazooka:
                  <font color="#00FF00">&nbsp;L2 + Circle Button</font>
                  <br>&nbsp; Death tornado spin:
                  <font color="#00FF00">&nbsp;Square Button (tap repeatedly)</font><br><br>
        &nbsp;</td>
	 </tr>
	</table>
       	</td>
     </tr>
</table>

      
