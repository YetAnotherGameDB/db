<!-- Game Controls Sectional -->

<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">BASIC CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick</font>
                  <br>&nbsp; Hang (towards edge):
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick</font>
                  <br>&nbsp; Enter scare mode / Enter some doors:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Jump / Finishing scare:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Double Jump:
                  <font color="#00FF00">&nbsp;X Button (twice)</font>
                  <br>&nbsp; Grab object (near it) / Drop object:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Attack:
                  <font color="#00FF00">&nbsp;Square Button + D-Pad or Left Analog Stick</font>
                  <br>&nbsp; Scare:
                  <font color="#00FF00">&nbsp;Circle, Triangle or Square Button</font>
                  <br>&nbsp; Unique aerial attack:
                  <font color="#00FF00">&nbsp;X + Square Button</font>
                  <br>&nbsp; Rotate view:
                  <font color="#00FF00">&nbsp;L2 or R2 Button</font>
                  <br>&nbsp; Pause game:
                  <font color="#00FF00">&nbsp;Start Button</font><br><br>
        &nbsp;</td>
	 </tr>
	</table>
