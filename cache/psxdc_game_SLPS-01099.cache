<!-- Game Controls Sectional -->

<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">COMPY/RAPTOR CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Lunge attack / speed burst underwater:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Snap attack:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Jump:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Evade:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Eat dead dinosaur or human to gain health:
                  <font color="#00FF00">&nbsp;R2 Button</font>
                  <br>&nbsp; Raptor call:
                  <font color="#00FF00">&nbsp;L2 Button</font>
                  <br>&nbsp; Pause game:
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">TYRANNOSAURUS CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Snap attack / toss captured hunter/dinosaur:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Lunge attack / toss captured hunter/dinosaur:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Jump / eat captured hunter / dinosaur:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Ram objects:
                  <font color="#00FF00">&nbsp;Triangle Button + D-Pad</font>
                  <br>&nbsp; Roar:
                  <font color="#00FF00">&nbsp;R2/L2 Button</font>
                  <br>&nbsp; Pause game:
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">HUMAN CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Jump and fire piton / hold onto piton:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Raise / lower yourself while hanging on piton:
                  <font color="#00FF00">&nbsp;D-pad up/down</font>
                  <br>&nbsp; Swing back and forth while piton is attached:
                  <font color="#00FF00">&nbsp;D-pad left/right</font>
                  <br>&nbsp; Fire weapon:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Jump:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Evade:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Cycle through weapons:
                  <font color="#00FF00">&nbsp;R2/L2 Button</font>
                  <br>&nbsp; Pause game:
                  <font color="#00FF00">&nbsp;Start Button</font><br><br>
        &nbsp;</td>
	 </tr>
	</table>
       	</td>
     </tr>
</table>

      
