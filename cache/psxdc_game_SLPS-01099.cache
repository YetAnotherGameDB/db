<!-- Game Cheats Sectional -->

<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
          		<br><u><i><font color="#FFFF00">MISC CODES:</font></i></u><br>
			&nbsp; Level select - Enter the following code three times -
                  &nbsp; <font color="#00FF00">Square, X, Circle, Triangle, Triangle, X, Square, Circle, Triangle, Circle, X, Square Level Select.</font>&nbsp;
			<br>&nbsp; Move Freely -
                  &nbsp; <font color="#00FF00">Hold Up + L1 and press Square + X on human hunter or human prey levels Move Freely.</font>&nbsp;<br>
          		<br><u><i><font color="#FFFF00">PASSWORD SCREEN CODES:</font></i></u><br>
			&nbsp; Play as General -
                  &nbsp; <font color="#00FF00">Square, Circle, Square, Circle, Circle, Circle, Square, Circle, Square, Circle, Square, Circle.</font>&nbsp;
			<br>&nbsp; Play as Human -
                  &nbsp; <font color="#00FF00">Circle, Circle, X, X, Triangle, Square, Square, Square, Circle, Circle, Square, Triangle.</font>&nbsp;
			<br>&nbsp; Play as Hunter with 99 lives and all DNA keys -
                  &nbsp; <font color="#00FF00">Square, Square, Triangle, Circle, X, Square, Square, Square, Square, X, Circle, Triangle.</font>&nbsp;
			<br>&nbsp; Play as male human -
                  &nbsp; <font color="#00FF00">Circle, Circle, X, X, Triangle, Square, Square, Square, Circle, Circle, Square, Triangle.</font>&nbsp;
			<br>&nbsp; Play as Raptor -
                  &nbsp; <font color="#00FF00">Square, X, Circle, Triangle, X, Circle, Square, Triangle, X, Square, Circle, X</font>&nbsp;
			<br>&nbsp; Play as T-Rex -
                  &nbsp; <font color="#00FF00">X, X, Circle, Triangle, Square, Square, Square, X, Triangle, Square, Triangle, Square</font>&nbsp;
			<br>&nbsp; View Compy Gallery -
                  &nbsp; <font color="#00FF00">X, Triangle, Triangle, Square, X, Circle, Triangle, Square, Triangle, Circle, X, Circle</font>&nbsp;
			<br>&nbsp; View General Gallery -
                  &nbsp; <font color="#00FF00">Square, Circle, Square, Circle, Circle, Circle, Square, Circle, Square, Circle, Square, Circle</font>&nbsp;
			<br>&nbsp; View Hunter Gallery -
                  &nbsp; <font color="#00FF00">Triangle, X, Square, Triangle, Circle, X, Square, Circle, Triangle, Square, X, Circle</font>&nbsp;
			<br>&nbsp; View Prey Gallery -
                  &nbsp; <font color="#00FF00">Triangle, Square, Circle, Square, X, Triangle, Triangle, Circle, X, Square, Triangle, Triangle</font>&nbsp;
			<br>&nbsp; View Raptor Gallery -
                  &nbsp; <font color="#00FF00">Circle, Square, Triangle, X, Circle, Triangle, Square, X, Circle, Square, X, Triangle</font>&nbsp;
			<br>&nbsp; View T-Rex Gallery -
                  &nbsp; <font color="#00FF00">Triangle, Triangle, Circle, Square, Triangle, X, Triangle, Square, Square, X, Triangle, Circle</font>&nbsp;<br>
<br>&nbsp;</td>
	 </tr>
	</table>
       	</td>

     </tr>
</table>

