<!-- Game Controls Sectional -->

<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">BATTING CONTROLS:</font></i></u><br>
                  &nbsp; Adjust position at plate -
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Swing -
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Hot to right -
                  <font color="#00FF00">&nbsp;X + R2 Button</font>
                  <br>&nbsp; Check Swing -
                  <font color="#00FF00">&nbsp;X + L2 Button</font>
                  <br>&nbsp; Bunt to left or right -
                  <font color="#00FF00">&nbsp;Square + L2 or R2 Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">PITCHING CONTROLS:</font></i></u><br>
                  &nbsp; Adjust position on mound -
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Pitch -
                  <font color="#00FF00">&nbsp;X Button + D-Pad Up</font>
                  <br>&nbsp; Change Up -
                  <font color="#00FF00">&nbsp;D-Pad Up</font>
                  <br>&nbsp; Fast ball -
                  <font color="#00FF00">&nbsp;D-Pad Down</font>
                  <br>&nbsp; Breaking Ball -
                  <font color="#00FF00">&nbsp;D-Pad Left or Right</font>
                  <br>&nbsp; Pick off -
                  <font color="#00FF00">&nbsp;Circle Button + D-Pad</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">FIELDING CONTROLS:</font></i></u><br>
                  &nbsp; Home -
                  <font color="#00FF00">&nbsp;D-Pad Down</font>
                  <br>&nbsp; First -
                  <font color="#00FF00">&nbsp;D-Pad Right</font>
                  <br>&nbsp; Second -
                  <font color="#00FF00">&nbsp;D-Pad Up</font>
                  <br>&nbsp; Third -
                  <font color="#00FF00">&nbsp;D-Pad Left</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">BEFORE CATCHING THE BALL CONTROLS:</font></i></u><br>
                  &nbsp; Switch controlled fielder -
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Dive for ball -
                  <font color="#00FF00">&nbsp;X Button + D-Pad</font>
                  <br>&nbsp; Jump for ball -
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Run for ball -
                  <font color="#00FF00">&nbsp;D-Pad</font>
			<br>&nbsp;<u><i><font color="#FFFF00">AFTER CATCHING BALL CONTROLS:</font></i></u><br>
                  &nbsp; Throw ball to Designated Base -
                  <font color="#00FF00">&nbsp;X Button + D-Pad</font>
                  <br>&nbsp; Run to base -
                  <font color="#00FF00">&nbsp;Circle Button + D-Pad</font>
                  <br>&nbsp; Tell cut off man to catch and hold -
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Disable cut off man -
                  <font color="#00FF00">&nbsp;X Button (twice)</font><br><br>	
				  &nbsp;</td>
	 </tr>
	</table>
       	</td>
     </tr>
</table>

      
