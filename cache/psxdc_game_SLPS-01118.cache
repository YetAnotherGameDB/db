		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">NORMAL CONTROLS:</font></i></u><br>
                  &nbsp; Run:
                  <font color="#00FF00">&nbsp;R1 Button + D-Pad</font>
                  <br>&nbsp; Sneak:
                  <font color="#00FF00">&nbsp;R2 Button + D-Pad</font>
                  <br>&nbsp; Jump:
                  <font color="#00FF00">&nbsp;Triangle Button or D-Pad up</font>
                  <br>&nbsp; Crouch:
                  <font color="#00FF00">&nbsp;X Button or D-Pad down</font>
                  <br>&nbsp; Throw:
                  <font color="#00FF00">&nbsp;Circle Button or D-Pad</font>
                  <br>&nbsp; Action:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Mount or turn:
                  <font color="#00FF00">&nbsp;D-Pad up</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">GAMESPEAK CONTROLS:</font></i></u><br>
                  &nbsp; Hello:
                  <font color="#00FF00">&nbsp;L1 + Triangle Button</font>
                  <br>&nbsp; Angry:
                  <font color="#00FF00">&nbsp;L1 + Circle Button</font>
                  <br>&nbsp; Wait:
                  <font color="#00FF00">&nbsp;L1 + X Button</font>
                  <br>&nbsp; Follow me:
                  <font color="#00FF00">&nbsp;L1 + Square Button</font>
                  <br>&nbsp; Whistle 1:
                  <font color="#00FF00">&nbsp;L2 + Triangle Button</font>
                  <br>&nbsp; Fart:
                  <font color="#00FF00">&nbsp;L2 + Circle Button</font>
                  <br>&nbsp; Whistle 2:
                  <font color="#00FF00">&nbsp;L2 + X Button</font>
                  <br>&nbsp; Laugh:
                  <font color="#00FF00">&nbsp;L2 + Square Button</font><br><br>
        &nbsp;</td>
	 </tr>
