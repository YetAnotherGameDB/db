<!-- Game Controls Sectional -->

<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
		<br>&nbsp;<u><i><font color="#FFFF00">ATTACKING CONTROLS:</font></i></u><br>
            &nbsp; Move player -
            <font color="#00FF00">D-Pad or Left Analog Stick</font>
            <br>&nbsp; Pass -
            <font color="#00FF00">X Button</font>
            <br>&nbsp; Through pass -
            <font color="#00FF00">X Button (Double tap)</font>			
            <br>&nbsp; Shoot -
            <font color="#00FF00">Circle Button</font>	
            <br>&nbsp; Chip shoot -
            <font color="#00FF00">Circle Button (Double tap)</font>				
            <br>&nbsp; Sprint -
            <font color="#00FF00">Triangle Button</font>
            <br>&nbsp; Lob -
            <font color="#00FF00">Square Button</font>
            <br>&nbsp; Flick the ball to yourself -
            <font color="#00FF00">Square Button (Double tap)</font>	
            <br>&nbsp; Passback pass -
            <font color="#00FF00">L1 Button then X to pass (press)</font>	
            <br>&nbsp; Control reciever (control player without ball) -
            <font color="#00FF00">L1 Button then X to pass (double tap)</font>	
            <br>&nbsp; Cancel passback mode -
            <font color="#00FF00">L1 Button then X to pass (tap again)</font>	
            <br>&nbsp; Jump a slide tackle -
            <font color="#00FF00">R1 Button (Press)</font>	
            <br>&nbsp; Dive -
            <font color="#00FF00">R1 Button (Double tap)</font>				
            <br>&nbsp; Pause game -
            <font color="#00FF00">Start Button</font><br>
		<br>&nbsp;<u><i><font color="#FFFF00">DEFENDING CONTROLS:</font></i></u><br>
            &nbsp; Move player -
            <font color="#00FF00">D-Pad or Left Analog Stick</font>
            <br>&nbsp; Switch player -
            <font color="#00FF00">X Button</font>	
            <br>&nbsp; Tackle -
            <font color="#00FF00">Circle Button</font>			
            <br>&nbsp; Sprint -
            <font color="#00FF00">Triangle Button</font>
            <br>&nbsp; Slide tackle -
            <font color="#00FF00">Square Button</font>
            <br>&nbsp; Vicious tackle lunge -
            <font color="#00FF00">L1 Button</font>	
            <br>&nbsp; Hip check or elbow -
            <font color="#00FF00">L1 Button (double tap)</font>	
            <br>&nbsp; Pause game -
            <font color="#00FF00">Start Button</font><br>
		<br>&nbsp;<u><i><font color="#FFFF00">WHEN THE KEEPER HAS THE BALL CONTROLS:</font></i></u><br>
            &nbsp; Throw to a team mate -
            <font color="#00FF00">X or Square Button</font>	
            <br>&nbsp; Through pass -
            <font color="#00FF00">X or Square Button (Double tap)</font>			
            <br>&nbsp; Drop kick -
            <font color="#00FF00">Circle Button</font>
            <br>&nbsp; Drop the ball -
            <font color="#00FF00">R1 Button</font><br>
		<br>&nbsp;<u><i><font color="#FFFF00">WHEN THE BALL IS IN MID-AIR CONTROLS:</font></i></u><br>
            &nbsp; Header pass -
            <font color="#00FF00">X Button</font>	
            <br>&nbsp; Header shot on goal -
            <font color="#00FF00">Circle Button</font>		
            <br>&nbsp; Header lob -
            <font color="#00FF00">Square Button</font>
            <br>&nbsp; High volley -
            <font color="#00FF00">Square Button (Tap & Hold)</font>		
            <br>&nbsp; Volleyed pass -
            <font color="#00FF00">X Button (Tap & Hold)</font>	
            <br>&nbsp; Volleyed shot -
            <font color="#00FF00">Circle Button (Tap & Hold)</font>
            <br>&nbsp; Slide/tackle lunge -
            <font color="#00FF00">L1 Button</font>
            <br>&nbsp; Hip check, elbow or push -
            <font color="#00FF00">L1 Button (Double tap)</font>			
            <br>&nbsp; Pause game -
            <font color="#00FF00">Start Button</font><br>
		<br>&nbsp;<u><i><font color="#FFFF00">FREE KICKS, CORNER KICKS OR GOAL KICKS CONTROLS:</font></i></u><br>
            &nbsp; Cycle normal/receiver/target mode -
            <font color="#00FF00">R1 Button</font>	
            <br>&nbsp; Set the height in normal mode -
            <font color="#00FF00">D-Pad or Left Analog Stick Up/Down</font>		
            <br>&nbsp; Set direction in normal mode -
            <font color="#00FF00">D-Pad or Left Analog Stick left or right</font>
            <br>&nbsp; Kick in normal mode -
            <font color="#00FF00">Square, X or Circle Button</font>		
            <br>&nbsp; Switch receiver in receiver mode -
            <font color="#00FF00">X Button</font>	
            <br>&nbsp; Kick in receiver mode -
            <font color="#00FF00">Square or Circle Button</font>
            <br>&nbsp; Move target in target mode -
            <font color="#00FF00">D-Pad or Left Analog Stick</font>
            <br>&nbsp; Lob in target mode -
            <font color="#00FF00">Square Button</font>	
            <br>&nbsp; Cross/clear target in target mode -
            <font color="#00FF00">Circle Button</font>	
            <br>&nbsp; Pass in target mode -
            <font color="#00FF00">X Button</font><br>
		<br>&nbsp;<u><i><font color="#FFFF00">THROW IN CONTROLS:</font></i></u><br>
            &nbsp; Switch receiving players in receiver mode -
            <font color="#00FF00">X Button</font>	
            <br>&nbsp; High throw in receiver mode -
            <font color="#00FF00">Square Button</font>		
            <br>&nbsp; Low throw in receiver mode -
            <font color="#00FF00">Circle Button</font>
            <br>&nbsp; Passback throw in receiver mode -
            <font color="#00FF00">Triangle Button</font>			
            <br>&nbsp; Throw in in Normal mode -
            <font color="#00FF00">Square, X or Circle Button</font>		
            <br>&nbsp; Move target in target mode -
            <font color="#00FF00">D-Pad or Left Analog Stick</font>
            <br>&nbsp; High throw in target mode -
            <font color="#00FF00">Square Button</font>	
            <br>&nbsp; Low throw in target mode -
            <font color="#00FF00">X or Circle Button</font><br><br>
			&nbsp;</td>
	 </tr>
	</table>
       	</td>
     </tr>
</table>

      
