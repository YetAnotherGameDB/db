	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">BASIC CONTROLS:</font></i></u><br>
                  &nbsp; Move plane:
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick</font>
                  <br>&nbsp; Take off:
                  <font color="#00FF00">&nbsp;Left Analog Stick down</font>
                  <br>&nbsp; Landing:
                  <font color="#00FF00">&nbsp;Left Analog Stick up</font>
                  <br>&nbsp; Tell passengers to put or remove belts:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Speed up:
                  <font color="#00FF00">&nbsp;Circle Button or Right Analog Stick up</font>
                  <br>&nbsp; Speed down / Brake:
                  <font color="#00FF00">&nbsp;X Button or Right Analog Stick down</font>
                  <br>&nbsp; Extend/retract landing gear:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Center ailerons:
                  <font color="#00FF00">&nbsp;L1 or R1 Button</font>
                  <br>&nbsp; Show or Hide wind indicator:
                  <font color="#00FF00">&nbsp;L2 Button</font>
                  <br>&nbsp; Change view:
                  <font color="#00FF00">&nbsp;Select Button</font>
                  <br>&nbsp; Pause game / Options:
                  <font color="#00FF00">&nbsp;Start Button</font><br><br>
        &nbsp;</td>
	 </tr>
	</table>
