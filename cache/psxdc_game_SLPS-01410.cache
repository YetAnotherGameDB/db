                  <font color="#00FF00">&nbsp;D-Pad down</font>
                  <br>&nbsp; Accelerate -
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Horn -
                  <font color="#00FF00">&nbsp;Circle Button</font>				  
                  <br>&nbsp; Change view -
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Brake -
                  <font color="#00FF00">&nbsp;Square Button</font>				  
                  <br>&nbsp; Shift Down -
                  <font color="#00FF00">&nbsp;L1 Button</font>	
                  <br>&nbsp; Shift Up -
                  <font color="#00FF00">&nbsp;R1 Button</font>							  				  
                  <br>&nbsp; Vibration on/off (dual shock controllers only)  -
                  <font color="#00FF00">&nbsp;Select Button</font>
                  <br>&nbsp; Pause game -
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">NEGCON CONTROLS:</font></i></u><br>
                  &nbsp; Turn wheels left or right:
                  <font color="#00FF00">&nbsp;Twisting Left or Right</font>
                  <br>&nbsp; Rear view -
                  <font color="#00FF00">&nbsp;A Button</font>
                  <br>&nbsp; Accelerate -
                  <font color="#00FF00">&nbsp;I Button</font>
                  <br>&nbsp; Change view -
                  <font color="#00FF00">&nbsp;B Button</font>
                  <br>&nbsp; Brake (reverse with automatics) -
                  <font color="#00FF00">&nbsp;II Button</font>				  
                  <br>&nbsp; Shift Down -
                  <font color="#00FF00">&nbsp;Left Shoulder Button</font>	
                  <br>&nbsp; Shift Up -
                  <font color="#00FF00">&nbsp;Right Shoulder Button</font>		
                  <br>&nbsp; Pause game -
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">MADCATZ WHEEL CONTROLS:</font></i></u><br>
                  &nbsp; Steer:
                  <font color="#00FF00">&nbsp;Turn wheel left or right</font>
                  <br>&nbsp; Rear view -
                  <font color="#00FF00">&nbsp;A Button</font>
                  <br>&nbsp; Accelerate -
                  <font color="#00FF00">&nbsp;Right Pedal</font>
                  <br>&nbsp; Change view -
                  <font color="#00FF00">&nbsp;B Button</font>
