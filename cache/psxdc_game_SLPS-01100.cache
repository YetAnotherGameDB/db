<!-- Game Controls Sectional -->

<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">ON GLOBAL SPHERE MAP CONTROLS:</font></i></u><br>
                  &nbsp; Move faster:
                  <font color="#00FF00">&nbsp;X/L2 Buttons</font>
                  <br>&nbsp; Display main menu:
                  <font color="#00FF00">&nbsp;Triangle / Select Button</font>
                  <br>&nbsp; Toggle window display:
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">IN TOWNS OR DUNGEONS CONTROLS:</font></i></u><br>
                  &nbsp; Move faster:
                  <font color="#00FF00">&nbsp;X/L2 Buttons</font>
                  <br>&nbsp; Talk with people, investigate items:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Display main menu:
                  <font color="#00FF00">&nbsp;Triangle/Select Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">IN MENU SCREENS CONTROLS:</font></i></u><br>
                  &nbsp; Select menu item / switch chartacters / status / equip screen:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Make selection:
                  <font color="#00FF00">&nbsp;Circle / L1 Button</font>
                  <br>&nbsp; Cancel:
                  <font color="#00FF00">&nbsp;X/L2 Button</font>
                  <br>&nbsp; Toggle item description (in item menu); enable/disable special skill (in special menu):
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Discard item:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Toggle adjust screen menu:
                  <font color="#00FF00">&nbsp;Start Button</font>
                  <br>&nbsp; Page up/down:
                  <font color="#00FF00">&nbsp;R1/R2 Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">BATTLE MENU CONTROLS:</font></i></u><br>
                  &nbsp; Movement:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Slash attack, jumping attack (during slash):
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Attack up:
                  <font color="#00FF00">&nbsp;D-Pad Up + Circle Button</font>
                  <br>&nbsp; Thrust attack:
                  <font color="#00FF00">&nbsp;D-Pad Down + Circle Button</font>
                  <br>&nbsp; Special skill 1:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Special skill 2:
                  <font color="#00FF00">&nbsp;D-Pad Up + X Button</font>
                  <br>&nbsp; Special skill 3:
                  <font color="#00FF00">&nbsp;D-Pad Down + X Button</font>
                  <br>&nbsp; Special skill 4:
                  <font color="#00FF00">&nbsp;D-Pad Left/Right + X Button</font>
                  <br>&nbsp; Defend:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Display battle menu:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Set battle operation mode:
                  <font color="#00FF00">&nbsp;Select Button</font>
                  <br>&nbsp; Reverse party order:
                  <font color="#00FF00">&nbsp;L1 Button</font>
                  <br>&nbsp; Change target:
                  <font color="#00FF00">&nbsp;R1 Button</font><br><br>
        &nbsp;</td>
	 </tr>
	</table>
