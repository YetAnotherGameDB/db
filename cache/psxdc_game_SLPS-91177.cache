<!-- Game Controls Sectional -->

<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">BEGINNER SETTINGS CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Attack, break barrel, talk:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Open a door, chest, or sarcophagus or pick up an item and place it in your inventory:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Toggle spell:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Cast spell:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; View automap:
                  <font color="#00FF00">&nbsp;R2 Button</font>
                  <br>&nbsp; Restore mana (use to cast spells):
                  <font color="#00FF00">&nbsp;R1 Button</font>
                  <br>&nbsp; Restore health:
                  <font color="#00FF00">&nbsp;L1 Button</font>
                  <br>&nbsp; Activate speed spell book:
                  <font color="#00FF00">&nbsp;L2 Button</font>
                  <br>&nbsp; In-game options:
                  <font color="#00FF00">&nbsp;Select Button</font>
                  <br>&nbsp; Pause game:
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">ADVANCED SETTINGS CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Attack, break barrel, talk:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Open a door, chest, or sarcophagus or pick up an item and place it in your inventory:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Use highlighted belt item:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Cast spell:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Combo button:
                  <font color="#00FF00">&nbsp;R2 Button</font>
                  <br>&nbsp; Restore mana (use to cast spells):
                  <font color="#00FF00">&nbsp;R1 Button</font>
                  <br>&nbsp; Restore health:
                  <font color="#00FF00">&nbsp;L1 Button</font>
                  <br>&nbsp; Activate speed spell book:
                  <font color="#00FF00">&nbsp;L2 Button</font>
                  <br>&nbsp; In-game options:
                  <font color="#00FF00">&nbsp;Select Button</font>
                  <br>&nbsp; Pause game:
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">COMBO CONTROLS:</font></i></u><br>
                  &nbsp; Inventory:
                  <font color="#00FF00">&nbsp;R2 + Square Button</font>
                  <br>&nbsp; Character info:
                  <font color="#00FF00">&nbsp;R2 + X Button</font>
                  <br>&nbsp; Belt item menu:
                  <font color="#00FF00">&nbsp;R2 + Circle Button</font>
                  <br>&nbsp; Use highlighted belt item:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Toggle spell:
                  <font color="#00FF00">&nbsp;R2 + Triangle Button</font>
                  <br>&nbsp; Quest log:
                  <font color="#00FF00">&nbsp;R2 + R1 Button</font>
                  <br>&nbsp; Full spell book:
                  <font color="#00FF00">&nbsp;R2 + L1 Button</font>
                  <br>&nbsp; View automap:
                  <font color="#00FF00">&nbsp;R2 + L2 Button</font><br><br>
        &nbsp;</td>
	 </tr>
	</table>
