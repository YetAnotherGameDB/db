<!-- Game Controls Sectional -->

<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">BATTING CONTROLS:</font></i></u><br>
                  &nbsp; Move batting cursor -
                  <font color="#00FF00">&nbsp;D-Pad</font>	  
                  <br>&nbsp; Swing -
                  <font color="#00FF00">&nbsp;X Button</font>	
                  <br>&nbsp; Bunt -
                  <font color="#00FF00">&nbsp;Circle Button</font>			  
                  <br>&nbsp; Hit and run -
                  <font color="#00FF00">&nbsp;R1 or R2 Button</font>				  
                  <br>&nbsp; Change swing type to contact or power -
                  <font color="#00FF00">&nbsp;L1 or L2 Button</font>	  
                  <br>&nbsp; Center battling cursor -
                  <font color="#00FF00">&nbsp;Select Button</font>				  
                  <br>&nbsp; Call time -
                  <font color="#00FF00">&nbsp;Start Button</font>
			<br>&nbsp;<u><i><font color="#FFFF00">RUNNING CONTROLS:</font></i></u><br>
                  &nbsp; Select base -
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; All runners advance one base -
                  <font color="#00FF00">&nbsp;Triangle Button</font>				  
                  <br>&nbsp; All runners return one base -
                  <font color="#00FF00">&nbsp;Circle Button</font>		
                  <br>&nbsp; All runners stop -
                  <font color="#00FF00">&nbsp;Triangle + Circle Button or Square + X Button</font>
                  <br>&nbsp; One runner advances to base -
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Run faster (press repeatedly) -
                  <font color="#00FF00">&nbsp;L1 or L2 Button or R1 or R2 Button</font>	  			  
                  <br>&nbsp; Call time -
                  <font color="#00FF00">&nbsp;Start Button</font>
			<br>&nbsp;<u><i><font color="#FFFF00">PITCHING CONTROLS:</font></i></u><br>
                  &nbsp; Select type of pitch -
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Pitch -
                  <font color="#00FF00">&nbsp;X Button</font>	
                  <br>&nbsp; Throw to first -
                  <font color="#00FF00">&nbsp;Circle Button</font>					  
                  <br>&nbsp; Throw to second -
                  <font color="#00FF00">&nbsp;Triangle Button</font>		
                  <br>&nbsp; Throw to third -
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Hide catcher's mitt -
                  <font color="#00FF00">&nbsp;R1 Button</font>	  
                  <br>&nbsp; Defense out -
                  <font color="#00FF00">&nbsp;L2 Button</font>	  
                  <br>&nbsp; Defense in -
                  <font color="#00FF00">&nbsp;L1 Button</font>	  
                  <br>&nbsp; Corners in -
                  <font color="#00FF00">&nbsp;R2 Button</font>	  					  
                  <br>&nbsp; Call time -
                  <font color="#00FF00">&nbsp;Start Button</font>
			<br>&nbsp;<u><i><font color="#FFFF00">FIELDING CONTROLS:</font></i></u><br>
                  &nbsp; Move fielder -
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Jump or dive -
                  <font color="#00FF00">&nbsp;X, Circle, Square or Triangle Button + D-Pad</font>
                  <br>&nbsp; Throw home -
                  <font color="#00FF00">&nbsp;X Button</font>	  				  
                  <br>&nbsp; Throw to first -
                  <font color="#00FF00">&nbsp;Circle Button</font>					  
                  <br>&nbsp; Throw to second -
                  <font color="#00FF00">&nbsp;Triangle Button</font>		
                  <br>&nbsp; Throw to third -
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Throw to cutoff man -
                  <font color="#00FF00">&nbsp;L1, R1, L2 or R2 Button</font>	  
                  <br>&nbsp; Call time -
                  <font color="#00FF00">&nbsp;Start Button</font><br><br>
				  &nbsp;</td>
	 </tr>
	</table>
       	</td>
     </tr>
</table>

      
