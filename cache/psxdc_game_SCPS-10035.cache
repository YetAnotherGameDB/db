	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">IN GAME CONTROLS:</font></i></u><br>
                  &nbsp; Move character - 
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Jump / Accept - 
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Hold to Run (in conjunction with D-Pad) - 
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Advance text when speaking / Swing weapon (hold to charge) / Pick up or throw items - 
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Use Equipped Item - 
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Options menu - 
                  <font color="#00FF00">&nbsp;Select Button</font>
                  <br>&nbsp; Bring up Status screen - 
                  <font color="#00FF00">&nbsp;Start / L1 / R2 Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">STATUS SCREEN CONTROLS:</font></i></u><br>
                  &nbsp; Scroll through selections - 
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Choose weapon / Item to equip - 
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Cancel out of Status Screen - 
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Bring up Secondary Status screen - 
                  <font color="#00FF00">&nbsp;L1 / R2 Buttons</font>
                  <br>&nbsp; Cancel out of Status screen - 
                  <font color="#00FF00">&nbsp;Start / L2 / R2 Button</font><br>
        &nbsp;</td>
	 </tr>
	</table>
       	</td>
     </tr>
</table>

      
