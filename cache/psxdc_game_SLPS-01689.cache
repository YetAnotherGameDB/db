<!-- Game Cheats Sectional -->

<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
				  <br><u><i><font color="#FFFF00">MISC CODES (Enter these codes on the main menu):</font></i></u><br>
			        &nbsp; Up Big Cars -
                  &nbsp; <font color="#00FF00">Hold X + Select and Press Right - Down - Left - Up - Right - Down - Left - Up - Down - Right - Up - Left - Down - Right - Up</font>&nbsp;
			        <br>&nbsp; Big Tracks -
                  &nbsp; <font color="#00FF00">Up, Left, Right, Down, Up, Left, Right, Down, Left, Up, Down, Right, Left, Up, Down</font>&nbsp;
			        <br>&nbsp; Deformed Cars -
                  &nbsp; <font color="#00FF00">Hold X and Press Right - Right - Up - Up - Down - Left - Down - Left - Right - Up - Down - Left - Right - Up - Right</font>&nbsp;
			        <br>&nbsp; Low Gravity -
                  &nbsp; <font color="#00FF00">Hold Circle + Start and press Right, Up, Down, Left, Right, Up, Down, Left, Right, Up, Down, Left, Right, Up, Left</font>&nbsp;
			        <br>&nbsp; Monochrome Mode -
                  &nbsp; <font color="#00FF00">Hold Select and press Right, Right, Right, Right, Up, Up, Up, Up, Down, Right, Up, Down, Right, Up, Left</font>&nbsp;
			        <br>&nbsp; Transparent Cars -
                  &nbsp; <font color="#00FF00">Hold Start and Press Up - Up - Right - Left - Down - Down - Left - Up - Right - Right - Up - Down - Left - Left - Down</font>&nbsp;
			        <br>&nbsp; Wide Turns -
                  &nbsp; <font color="#00FF00">Hold X + Slect and Press Down - Down - Left - Down - Down - Down - Left - Down - Up - Down - Right - Left - Right - Left - Up</font>&nbsp;<br>
				  <br><u><i><font color="#FFFF00">ACTION REPLAY CODES:</font></i></u><br>
			        &nbsp; Joker Command -
                  &nbsp; <font color="#00FF00"><br>D01C55F4 0000</font>&nbsp;
			        <br>&nbsp; Infinite money -
                  &nbsp; <font color="#00FF00"><br>80010290 FFFF<br>80010292 0FFF</font>&nbsp;
			        <br>&nbsp; Infinite fuel and tire brake -
                  &nbsp; <font color="#00FF00"><br>301E1D36 0010<br>301E1D39 00FF<br>301E1D3D 00FF</font>&nbsp;<br><br>
	 </tr>
	</table>
