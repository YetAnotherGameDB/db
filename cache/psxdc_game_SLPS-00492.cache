			<br>&nbsp;<u><i><font color="#FFFF00">BASIC CONTROLS:</font></i></u><br>
                  &nbsp; Forward:
                  <font color="#00FF00">&nbsp;D-Pad up</font>
                  <br>&nbsp; Backward:
                  <font color="#00FF00">&nbsp;D-Pad down</font>
                  <br>&nbsp; Turn left or right:
                  <font color="#00FF00">&nbsp;D-Pad left or right</font>
                  <br>&nbsp; Change gun:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Fire Missile:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Fire Special:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Fire Gun:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Look up or down:
                  <font color="#00FF00">&nbsp;R1 or L1 Button</font>
                  <br>&nbsp; Sidestep left or right:
                  <font color="#00FF00">&nbsp;L2 or R2 Button</font>
                  <br>&nbsp; Skip video sequence:
                  <font color="#00FF00">&nbsp;Select Button</font>
                  <br>&nbsp; Pause game:
                  <font color="#00FF00">&nbsp;Start Button</font><br><br>
