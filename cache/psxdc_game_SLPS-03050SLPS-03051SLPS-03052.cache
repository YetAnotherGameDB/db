<!-- Game Controls Sectional -->

<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">MENU CONTROLS:</font></i></u><br>
                  &nbsp; Select menu item:
                  <font color="#00FF00">&nbsp;D-Pad + X Button</font>
                  <br>&nbsp; Cancel:
                  <font color="#00FF00">&nbsp;Circle Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">MAP SCREEN CONTROLS:</font></i></u><br>
                  &nbsp; Navigation map and compass:
                  <font color="#00FF00">&nbsp;Start Button</font>
                  <br>&nbsp; Enter towns and dungeons:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Cancel selection:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Open the main menu:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Open the travel menu:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Game hints:
                  <font color="#00FF00">&nbsp;Select Button</font>
                  <br>&nbsp; Rotate the screen:
                  <font color="#00FF00">&nbsp;L1 or R1 Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">TOWN OR DUNGEON SCREEN CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick</font>
                  <br>&nbsp; Talk / Explore:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Run:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Open the main menu:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Shoot sorcerer's ring:
                  <font color="#00FF00">&nbsp;R1 Button</font>
                  <br>&nbsp; Shoot freeze ring:
                  <font color="#00FF00">&nbsp;L1 Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">MAIN MENU SCREEN CONTROLS:</font></i></u><br>
                  &nbsp; Select command:
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick</font>
                  <br>&nbsp; Confirm selection:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Cancel:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Remove item in equip screen, change auto cook setting, throw away inventory items in item screen:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Toggle item or attribute description, toggle character skills in skills screen:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Adjust screen:
                  <font color="#00FF00">&nbsp;Start Button</font>
                  <br>&nbsp; Scroll menu screen:
                  <font color="#00FF00">&nbsp;L1 or R1 Button</font>
                  <br>&nbsp; Scroll left or right to select an option:
                  <font color="#00FF00">&nbsp;L2 or R2 Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">DURING BATTLE CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick</font>
                  <br>&nbsp; Switch target:
                  <font color="#00FF00">&nbsp;R1 Button + D-Pad</font>
                  <br>&nbsp; Attack:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Special skill 1:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Defend:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Battle menu:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Switch the battle mode of the player character:
                  <font color="#00FF00">&nbsp;Select Button</font>
                  <br>&nbsp; Scroll battle screen:
                  <font color="#00FF00">&nbsp;Square Button + D-Pad Left or Right</font>
                  <br>&nbsp; Zoom battle screen:
                  <font color="#00FF00">&nbsp;Square Button + D-Pad Up or Down</font>
                  <br>&nbsp; Pause:
                  <font color="#00FF00">&nbsp;Start Button</font>
                  <br>&nbsp; Dash:
                  <font color="#00FF00">&nbsp;D-Pad or Left analog stick twice</font>
                  <br>&nbsp; Command all allies to jump:
                  <font color="#00FF00">&nbsp;L1 Button + D-Pad Up</font>
                  <br>&nbsp; Command all allies to gather:
                  <font color="#00FF00">&nbsp;L1 Button + D-Pad Down</font>
                  <br>&nbsp; Escape battle:
                  <font color="#00FF00">&nbsp;D-Pad Left or right</font>
                  <br>&nbsp; Special skill 2:
                  <font color="#00FF00">&nbsp;Circle Button + D-Pad up</font>
                  <br>&nbsp; Special skill 3:
                  <font color="#00FF00">&nbsp;Circle Button + D-Pad left or right</font>
                  <br>&nbsp; Special skill 4:
                  <font color="#00FF00">&nbsp;Circle Button + D-Pad down</font>
                  <br>&nbsp; Special skills shortcuts:
                  <font color="#00FF00">&nbsp;L2 or R2 Button</font><br><br>
        &nbsp;</td>
	 </tr>
	</table>
       	</td>
     </tr>
</table>

      
