<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">BASIC CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick</font>
                  <br>&nbsp; Jump -
                  <font color="#00FF00">&nbsp;X Button</font>
				  <br>&nbsp; Kick -
                  <font color="#00FF00">&nbsp;Circle Button</font>
				  <br>&nbsp; Punch -
                  <font color="#00FF00">&nbsp;Square Button</font>
				  <br>&nbsp; Web Trap -
                  <font color="#00FF00">&nbsp;Triangle Button</font>
				  <br>&nbsp; Jumping punch -
                  <font color="#00FF00">&nbsp;X + Square Button</font>
				  <br>&nbsp; Jumping kick -
                  <font color="#00FF00">&nbsp;X + Circle Button</font>
				  <br>&nbsp; Grab -
                  <font color="#00FF00">&nbsp;Square + Triangle or Circle + Triangle Button Button</font>
				  <br>&nbsp; Grab & Punch -
                  <font color="#00FF00">&nbsp;Square + Triangle + Square Button</font>
				  <br>&nbsp; Grab & Kick -
                  <font color="#00FF00">&nbsp;Circle + Triangle + Circle Button</font>
				  <br>&nbsp; Web spikes -
                  <font color="#00FF00">&nbsp;Triangle Button + D-Pad Left</font>
				  <br>&nbsp; Web dome -
                  <font color="#00FF00">&nbsp;Triangle Button + D-Pad Right</font>
				  <br>&nbsp; Break web dome -
                  <font color="#00FF00">&nbsp;Square or Circle or X Button</font>
				  <br>&nbsp; Impact web -
                  <font color="#00FF00">&nbsp;Triangle Button + D-Pad Up</font>
				  <br>&nbsp; Web yank -
                  <font color="#00FF00">&nbsp;Triangle Button + D-Pad Down</font>				  
				  <br>&nbsp; Web zip line -
                  <font color="#00FF00">&nbsp;R1 Button</font>		
				  <br>&nbsp; Web yank overhead -
                  <font color="#00FF00">&nbsp;Square + Triangle Button</font>		
				  <br>&nbsp; Web swing -
                  <font color="#00FF00">&nbsp;R2 or X + X Button (kid mode)</font>		
				  <br>&nbsp; Target mode -
                  <font color="#00FF00">&nbsp;L1 Button</font>		
				  <br>&nbsp; Auto target -
                  <font color="#00FF00">&nbsp;L2 Button</font>		
				  <br>&nbsp; Aerial impact web -
                  <font color="#00FF00">&nbsp;Triangle Button + D-Pad Up (during swing)</font>		
				  <br>&nbsp; Jumping impact web -
                  <font color="#00FF00">&nbsp;X + Triangle + D-Lad Up (in air)</font>						  
				  <br>&nbsp; Pause game -
                  <font color="#00FF00">&nbsp;Start Button</font><br><br>
				  &nbsp;</td>
	 </tr>
	</table>
