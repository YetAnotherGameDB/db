	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">BASIC CONTROLS:</font></i></u><br>
                  &nbsp; Steer:
                  <font color="#00FF00">&nbsp;D-Pad or Analog Stick left or right</font>
                  <br>&nbsp; Accelerate:
                  <font color="#00FF00">&nbsp;D-Pad or Analog Stick up or X Button</font>
                  <br>&nbsp; Reverse:
                  <font color="#00FF00">&nbsp;D-Pad or Analog Stick down</font>
                  <br>&nbsp; Tight turn:
                  <font color="#00FF00">&nbsp;D-Pad or Left Stick Left/Right + Square Button</font>
                  <br>&nbsp; Power slide:
                  <font color="#00FF00">&nbsp;D-Pad or Left Stick Left/Right + R1 Button</font>
                  <br>&nbsp; Brake:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Hop:
                  <font color="#00FF00">&nbsp;L1 or R1 Button</font>
                  <br>&nbsp; Launch weapon or power-up:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Toggle view:
                  <font color="#00FF00">&nbsp;L2 Button</font>
                  <br>&nbsp; Rear view:
                  <font color="#00FF00">&nbsp;R2 Button</font>
                  <br>&nbsp; Toggle map / Speedometer:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Pause game:
                  <font color="#00FF00">&nbsp;Start Button</font><br><br>
        &nbsp;</td>
	 </tr>
	</table>
