<!-- Game Controls Sectional -->

<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">IN-GAME CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick</font>
                  <br>&nbsp; Draw / Holster weapon / Return to normal view (while using binoculars):
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Action:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Jump:
                  <font color="#00FF00">&nbsp;Square or L3 Button</font>
                  <br>&nbsp; Dive and roll forward:
                  <font color="#00FF00">&nbsp;Square Button (while sprinting)</font>
                  <br>&nbsp; Roll:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Look:
                  <font color="#00FF00">&nbsp;L1 Button or Right Analog Stick</font>
                  <br>&nbsp; Crawl:
                  <font color="#00FF00">&nbsp;L2 Button + D-Pad or Left Analog Stick</font>
                  <br>&nbsp; Duck:
                  <font color="#00FF00">&nbsp;L2 Button</font>
                  <br>&nbsp; Sidestep right or left:
                  <font color="#00FF00">&nbsp;R1 Button + D-Pad or Left Analog Stick</font>
                  <br>&nbsp; Sprint when moving forward:
                  <font color="#00FF00">&nbsp;R2 Button</font>
                  <br>&nbsp; Draw / Throw flares:
                  <font color="#00FF00">&nbsp;Select + R1 Button</font>
                  <br>&nbsp; Press to activate action:
                  <font color="#00FF00">&nbsp;R3 Button</font>
                  <br>&nbsp; Zoom in/out (while using binoculars/laser light):
                  <font color="#00FF00">&nbsp;L2 / R2 Button</font>
                  <br>&nbsp; Inventory:
                  <font color="#00FF00">&nbsp;Select Button</font>
                  <br>&nbsp; Pause game:
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">MOTORCYCLE AND SIDECAR CONTROLS:</font></i></u><br>
                  &nbsp; Climb on:
                  <font color="#00FF00">&nbsp;Position Lara next to the motorcycle and press X or L3</font>
                  <br>&nbsp; Turn left or right:
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick left or right</font>
                  <br>&nbsp; Pull back:
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick down</font>
                  <br>&nbsp; Accelerate:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Brake:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Dismount (when stationary):
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Nitro:
                  <font color="#00FF00">&nbsp;R2 Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">JEEP CONTROLS:</font></i></u><br>
                  &nbsp; Climb on:
                  <font color="#00FF00">&nbsp;Position Lara next to the motorcycle and press X or L3</font>
                  <br>&nbsp; Turn left or right:
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick left or right</font>
                  <br>&nbsp; Accelerate:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Brake:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Shift up / down:
                  <font color="#00FF00">&nbsp;R1 / R2 Button</font>
                  <br>&nbsp; Exit jeep (when stationary):
                  <font color="#00FF00">&nbsp;Circle Button</font><br>
        &nbsp;</td>
	 </tr>
	</table>
       	</td>
     </tr>
</table>

      
