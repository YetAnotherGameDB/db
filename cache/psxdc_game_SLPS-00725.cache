			<br>&nbsp;<u><i><font color="#FFFF00">NORMAL CONTROLS:</font></i></u><br>
                  &nbsp; Aim crosshair - 
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Fire gun - 
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Reload - 
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Pause game - 
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">MOUSE CONTROLS:</font></i></u><br>
                  &nbsp; Aim crosshair - 
                  <font color="#00FF00">&nbsp;Move mouse</font>
                  <br>&nbsp; Fire gun - 
                  <font color="#00FF00">&nbsp;Left Mouse Button</font>
                  <br>&nbsp; Reload - 
                  <font color="#00FF00">&nbsp;Right Mouse Button</font>
                  <br>&nbsp; Throw grenade - 
                  <font color="#00FF00">&nbsp;Left Click On The Grenade Displayed On-Screen</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">ARCADE GUN CONTROLS:</font></i></u><br>
                  &nbsp; Aim crosshair - 
                  <font color="#00FF00">&nbsp;Move gun</font>
                  <br>&nbsp; Throw grenade - 
                  <font color="#00FF00">&nbsp;Fire at grenade</font>
                  <br>&nbsp; Fire gun - 
                  <font color="#00FF00">&nbsp;Pull trigger</font>
                  <br>&nbsp; Reload - 
                  <font color="#00FF00">&nbsp;Point gun off-screen pull trigger</font>
                  <br>&nbsp; Pause game - 
                  <font color="#00FF00">&nbsp;Start Button</font><br><br>
        &nbsp;</td>
	 </tr>
	</table>
