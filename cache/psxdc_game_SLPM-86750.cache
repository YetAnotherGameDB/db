	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">BASIC CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Guard:
                  <font color="#00FF00">&nbsp;D-Pad Left (If the player faces right)</font>
                  <br>&nbsp; Light kick:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Heavy kick:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Light punch:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Heavy punch:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Throw:
                  <font color="#00FF00">&nbsp;R2 + Square or Triangle Button</font>
                  <br>&nbsp; Throw (when opponent is crouched):
                  <font color="#00FF00">&nbsp;R2 + Square or Triangle Button + D-Pad down</font>
                  <br>&nbsp; Dodge backward:
                  <font color="#00FF00">&nbsp;R1 + X or Circle Button Button</font>
                  <br>&nbsp; Dodge forward:
                  <font color="#00FF00">&nbsp;D-Pad down + R1 + X or Circle Button Button</font>
                  <br>&nbsp; Get up on the spot:
                  <font color="#00FF00">&nbsp;D-Pad Up (when falling down)</font>
                  <br>&nbsp; Roll to the side and get up:
                  <font color="#00FF00">&nbsp;D-Pad Down (when falling down)</font>
                  <br>&nbsp; Roll forward and get up:
                  <font color="#00FF00">&nbsp;D-Pad Right (when falling down)</font>
                  <br>&nbsp; Roll back and get up:
                  <font color="#00FF00">&nbsp;D-Pad Left (when falling down)</font>
                  <br>&nbsp; Get up attack:
                  <font color="#00FF00">&nbsp;Square, X, Circle or Triangle Button (when getting up)</font>
                  <br>&nbsp; Pause game:
                  <font color="#00FF00">&nbsp;Start Button</font><br>
     &nbsp;</td>
	 </tr>
	</table>
