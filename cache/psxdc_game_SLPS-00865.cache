<!-- Game Controls Sectional -->

<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">EXPLORATION MODE CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Run:
                  <font color="#00FF00">&nbsp;D-Pad up + X Button</font>
                  <br>&nbsp; Select action:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Relax or explore:
                  <font color="#00FF00">&nbsp;L2 Button</font>
                  <br>&nbsp; Combat stance / practice moves:
                  <font color="#00FF00">&nbsp;R2 Button</font>
                  <br>&nbsp; Pause game / Menu:
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">COMBAT MODE CONTROLS:</font></i></u><br>
                  &nbsp; Dash:
                  <font color="#00FF00">&nbsp;D-Pad up (twice)</font>
                  <br>&nbsp; Run:
                  <font color="#00FF00">&nbsp;D-Pad up and hold</font>
                  <br>&nbsp; Back flip:
                  <font color="#00FF00">&nbsp;D-Pad down</font>
                  <br>&nbsp; Back flip with 180 degree turn:
                  <font color="#00FF00">&nbsp;D-Pad up and hold</font>
                  <br>&nbsp; Jump:
                  <font color="#00FF00">&nbsp;R1 Button</font>
                  <br>&nbsp; Crouch:
                  <font color="#00FF00">&nbsp;L1 Button</font>
                  <br>&nbsp; Left kick:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Right kick:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Left punch:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Right punch:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Sweep kick:
                  <font color="#00FF00">&nbsp;L1 + X or Circle Button</font>
                  <br>&nbsp; Palm strike:
                  <font color="#00FF00">&nbsp;Hold L1 + Triangle + Square Button</font>
                  <br>&nbsp; Scissor kick:
                  <font color="#00FF00">&nbsp;Hold L1 While Letting Go Press X Button</font>
                  <br>&nbsp; Jump kick:
                  <font color="#00FF00">&nbsp;R1 + X Button</font>
                  <br>&nbsp; Knee grapple (must be near opponent):
                  <font color="#00FF00">&nbsp;Triangle + Circle Button</font>
                  <br>&nbsp; Tackle:
                  <font color="#00FF00">&nbsp;Dash + Square + X Button</font>
                  <br>&nbsp; Uppercut:
                  <font color="#00FF00">&nbsp;D-Pad Forward + Square Button</font>
                  <br>&nbsp; Spinning back punch:
                  <font color="#00FF00">&nbsp;D-Pad Down + Triangle Button</font>
                  <br>&nbsp; Back kick:
                  <font color="#00FF00">&nbsp;D-Pad Down + X Button</font>
                  <br>&nbsp; Side kick combos:
                  <font color="#00FF00">&nbsp;D-Pad Down + X,X,X Button</font>
                  <br>&nbsp; Grapple throw:
                  <font color="#00FF00">&nbsp;Square + X Button</font>
                  <br>&nbsp; Jab side kick combo:
                  <font color="#00FF00">&nbsp;Triangle + X Button</font>
                  <br>&nbsp; Round house combo:
                  <font color="#00FF00">&nbsp;X + Circle Button</font>
                  <br>&nbsp; Map:
                  <font color="#00FF00">&nbsp;Select Button</font>
                  <br>&nbsp; Pause game:
                  <font color="#00FF00">&nbsp;Start Button</font><br>
     &nbsp;</td>
	 </tr>
	</table>
       	</td>
     </tr>
</table>

      
