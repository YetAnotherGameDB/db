<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
          		<br><u><i><font color="#FFFF00">MISC CODES:</font></i></u><br>
			&nbsp; All attacks - 
                  &nbsp; <font color="#00FF00">Pause the game and press L2, R2, R1, L1</font>&nbsp;
			<br>&nbsp; Big Head Mode - 
                  &nbsp; <font color="#00FF00">While paused press L1 + L2 + R2 + Down</font>&nbsp;
			<br>&nbsp; Cyborg Mode - 
                  &nbsp; <font color="#00FF00">While paused press R1 + R2 + Triangle + Circle</font>&nbsp;
			<br>&nbsp; Invencibility - 
                  &nbsp; <font color="#00FF00">Pause the game and press Circle + Square + Right, then release the buttons and press Left + R1 + R2</font>&nbsp;
			<br>&nbsp; Level Select - 
                  &nbsp; <font color="#00FF00">Pause the game, hold R1 and press Square, Triangle, Circle, X</font>&nbsp;
			<br>&nbsp; Sphere Mode - 
                  &nbsp; <font color="#00FF00">Pause the game and press L1 + L2 + Circle + Square</font>&nbsp;
			<br>&nbsp; Unlock Morgone Level - 
                  &nbsp; <font color="#00FF00">Pause the game and press X, X, Square, X, Square, Square, Triangle, Circle</font>&nbsp;<br>
          		<br><u><i><font color="#FFFF00">LEVEL PASSWORD CODES:</font></i></u><br>
			&nbsp; Desert Moon - 
                  &nbsp; <font color="#00FF00">Circle, X, X, X, Triangle, Circle, Triangle, Triangle</font>&nbsp;
			<br>&nbsp; Forest Moon - 
                  &nbsp; <font color="#00FF00">Circle, Triangle, Square, Circle, Square, Square, Triangle, Triangle</font>&nbsp;
			<br>&nbsp; Garden Moon - 
                  &nbsp; <font color="#00FF00">Circle, X, X, Triangle, Circle, Circle, x, Triangle</font>&nbsp;
			<br>&nbsp; Proteus Moon - 
                  &nbsp; <font color="#00FF00">X, X, Square, X, Square, Square, Triangle, Circle</font>&nbsp;<br>
	 </tr>
	</table>
