	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">POOYAN CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Arrows and meat:
                  <font color="#00FF00">&nbsp;X or Circle Button</font>
                  <br>&nbsp; Pause game:
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">SCRAMBLE CONTROLS:</font></i></u><br>
                  &nbsp; Move ship:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Drop bombs:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Shoot:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Pause game:
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">YIE AR KUNG-FU CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Kick:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Punch:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Pause game:
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">ROC 'N ROPE CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Flashlight:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Connect ropes:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Pause game:
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">SHAO-LIN'S ROAD CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Jump:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Kick:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Pause game:
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">CIRCUS CHARLIE CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Jump:
                  <font color="#00FF00">&nbsp;X or Circle Button</font>
                  <br>&nbsp; Pause game:
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">SUPER COBRA CONTROLS:</font></i></u><br>
                  &nbsp; Move ship:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Drop bombs:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Shoot:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Pause game:
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">ROAD FIGHTER CONTROLS:</font></i></u><br>
                  &nbsp; Move car:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; High gear:
