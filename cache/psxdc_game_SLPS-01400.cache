<!-- Game Controls Sectional -->

<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">BASIC CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad</font>
                  <br>&nbsp; Activate switches -
                  <font color="#00FF00">&nbsp;X Button</font>
				  <br>&nbsp; Break kick -
                  <font color="#00FF00">&nbsp;Circle Button</font>
				  <br>&nbsp; Jump -
                  <font color="#00FF00">&nbsp;Triangle Button</font>
				  <br>&nbsp; Break punch -
                  <font color="#00FF00">&nbsp;Square Button</font>
				  <br>&nbsp; Roll forward -
                  <font color="#00FF00">&nbsp;L1 Button</font>
				  <br>&nbsp; Precision movement -
                  <font color="#00FF00">&nbsp;L2 Button</font>
				  <br>&nbsp; Restore physical condition -
                  <font color="#00FF00">&nbsp;L1 + L2 Button</font>				  
				  <br>&nbsp; View in first person camera -
                  <font color="#00FF00">&nbsp;R2 Button</font>
				  <br>&nbsp; Look up/down -
                  <font color="#00FF00">&nbsp;R2 Button + D-Pad Up/Down</font>
				  <br>&nbsp; Look left/right -
                  <font color="#00FF00">&nbsp;R2 Button + D-Pad Left/Right</font>
				  <br>&nbsp; Hold to pan 360 degrees from floor to ceiling -
                  <font color="#00FF00">&nbsp;R2 Button + D-Pad</font>				  
				  <br>&nbsp; Pause game -
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">COMBAT BUTTON COMBO CONTROLS:</font></i></u><br>
                  &nbsp; Left kick:
                  <font color="#00FF00">&nbsp;X Button</font>
				  <br>&nbsp; Right kick -
                  <font color="#00FF00">&nbsp;Circle Button</font>
				  <br>&nbsp; Right cross -
                  <font color="#00FF00">&nbsp;Triangle Button</font>
				  <br>&nbsp; Left jab -
                  <font color="#00FF00">&nbsp;Square Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">COMBAT MAGIC ATTACKS CONTROLS:</font></i></u><br>
                  &nbsp; Fireball:
                  <font color="#00FF00">&nbsp;Back, Back, Down, Down + X Button</font>
				  <br>&nbsp; Magical blast -
                  <font color="#00FF00">&nbsp;Back, Forward + Square Button</font>
				  <br>&nbsp; Hell gauntlet -
                  <font color="#00FF00">&nbsp;Back, Forward + Triangle Button</font>
				  <br>&nbsp; Ice blast -
                  <font color="#00FF00">&nbsp;Forward, Forward, Down, Down + Circle Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">COMBAT SPECIAL ATTACKS CONTROLS:</font></i></u><br>
                  &nbsp; Elbow smash:
                  <font color="#00FF00">&nbsp;Forward, Forward + Square Button</font>
				  <br>&nbsp; Right kick -
                  <font color="#00FF00">&nbsp;Forward, Forward + Circle Button</font>
				  <br>&nbsp; Right cross -
                  <font color="#00FF00">&nbsp;Forward, Forward + Triangle Button</font>
				  <br>&nbsp; Left kick -
                  <font color="#00FF00">&nbsp;Forward, Forward + X Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">COMBAT CAPE/CHAIN ATTACKS CONTROLS:</font></i></u><br>
                  &nbsp; Cape/chain attack right:
                  <font color="#00FF00">&nbsp;1/2 Circle Back to Front + Circle Button</font>
				  <br>&nbsp; Cape/chain attack left -
                  <font color="#00FF00">&nbsp;1/2 Circle Back to Front + Square Button</font>
				  <br>&nbsp; Arm rip -
                  <font color="#00FF00">&nbsp;1/2 Circle Front to Back + X Button</font><br>				  
				  &nbsp;</td>
	 </tr>
	</table>
       	</td>
     </tr>
</table>

      
