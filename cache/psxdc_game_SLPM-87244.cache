<!-- Game Controls Sectional -->

<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">BATTING CONTROLS:</font></i></u><br>
                  &nbsp; Position batter -
                  <font color="#00FF00">&nbsp;D-Pad</font>	  
                  <br>&nbsp; Normal swing -
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Power swing -
                  <font color="#00FF00">&nbsp;X Button + D-Pad Up</font>
                  <br>&nbsp; Bunt  -
                  <font color="#00FF00">&nbsp;Triangle Button + D-Pad</font>				  
                  <br>&nbsp; Lead base runner -
                  <font color="#00FF00">&nbsp;X Button + D-Pad</font>
                  <br>&nbsp; Lead all base runners -
                  <font color="#00FF00">&nbsp;L1 Button</font>
                  <br>&nbsp; Time, change batter -
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">BASE RUNNING CONTROLS:</font></i></u><br>
                  &nbsp; Advance base runner -
                  <font color="#00FF00">&nbsp;X or Triangle Button + D-Pad</font>	  
                  <br>&nbsp; Return base runner -
                  <font color="#00FF00">&nbsp;Circle Button + D-Pad</font>
                  <br>&nbsp; Return all base runners -
                  <font color="#00FF00">&nbsp;R1 Button</font>
                  <br>&nbsp; Advance all base runners -
                  <font color="#00FF00">&nbsp;L1 Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">PITCHING CONTROLS:</font></i></u><br>
                  &nbsp; Position pitcher -
                  <font color="#00FF00">&nbsp;D-Pad</font>	  
                  <br>&nbsp; Make angle -
                  <font color="#00FF00">&nbsp;X Button + D-Pad Left or Right</font>
                  <br>&nbsp; Fast ball -
                  <font color="#00FF00">&nbsp;X Button + D-Pad Up</font>
                  <br>&nbsp; Slow ball -
                  <font color="#00FF00">&nbsp;X Button + D-Pad Down</font>
                  <br>&nbsp; Fork -
                  <font color="#00FF00">&nbsp;X Button + D-Pad Down (hold after pitch)</font>				  
                  <br>&nbsp; Curve, screw -
                  <font color="#00FF00">&nbsp;X Button + D-Pad Left or Right (after pitch)</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">FIELDING CONTROLS:</font></i></u><br>
                  &nbsp; Move -
                  <font color="#00FF00">&nbsp;D-Pad Left or Right</font>	  
                  <br>&nbsp; Jump -
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Dive / Throw -
                  <font color="#00FF00">&nbsp;X Button + D-Pad</font>
                  <br>&nbsp; Run to base -
                  <font color="#00FF00">&nbsp;Circle or Triangle Button + D-Pad</font><br><br>
				  &nbsp;</td>
	 </tr>
	</table>
       	</td>
     </tr>
</table>

      
