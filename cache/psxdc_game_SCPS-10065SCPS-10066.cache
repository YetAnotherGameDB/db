                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Increase thrust:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Hover up:
                  <font color="#00FF00">&nbsp;L1 Button</font>
                  <br>&nbsp; Hover down:
                  <font color="#00FF00">&nbsp;L2 Button</font>
                  <br>&nbsp; Target toggle:
                  <font color="#00FF00">&nbsp;R1 Button</font>
                  <br>&nbsp; Air brake:
                  <font color="#00FF00">&nbsp;R2 Button</font>
                  <br>&nbsp; Toggle camera views:
                  <font color="#00FF00">&nbsp;Select Button</font>
                  <br>&nbsp; Pause game:
                  <font color="#00FF00">&nbsp;Start Button</font><br>
			<br>&nbsp;<u><i><font color="#FFFF00">ANALOG CONTROLLER CONTROLS:</font></i></u><br>
                  &nbsp; Move nose direction of Havoc:
                  <font color="#00FF00">&nbsp;Left Analog Stick</font>
                  <br>&nbsp; Look around:
                  <font color="#00FF00">&nbsp;Right Analog Stick</font>
                  <br>&nbsp; Fire weapon:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Weapon cycle:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Decrease thrust:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Increase thrust:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Hover up:
                  <font color="#00FF00">&nbsp;L1 Button</font>
                  <br>&nbsp; Hover down:
                  <font color="#00FF00">&nbsp;L2 Button</font>
                  <br>&nbsp; Target toggle:
                  <font color="#00FF00">&nbsp;R1 Button</font>
                  <br>&nbsp; Air brake:
                  <font color="#00FF00">&nbsp;R2 Button</font>
                  <br>&nbsp; Toggle camera views:
                  <font color="#00FF00">&nbsp;Select Button</font>
