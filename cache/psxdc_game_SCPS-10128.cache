<table border="0" width="100%" id="table16" cellpadding="0">
	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
			<br>&nbsp;<u><i><font color="#FFFF00">BASIC CONTROLS:</font></i></u><br>
                  &nbsp; Move character:
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick</font>
                  <br>&nbsp; Jump -
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Glide -
                  <font color="#00FF00">&nbsp;X Button (twice)</font>
                  <br>&nbsp; Glide, hover and land -
                  <font color="#00FF00">&nbsp;X Button (twice) + Triangle Button</font>				  
				  <br>&nbsp; Flame or spit objects -
                  <font color="#00FF00">&nbsp;Circle Button</font>
				  <br>&nbsp; Charge -
                  <font color="#00FF00">&nbsp;Square Button</font>
				  <br>&nbsp; Talk, free look mode -
                  <font color="#00FF00">&nbsp;Triangle Button</font>				  
				  <br>&nbsp; Pan camera -
                  <font color="#00FF00">&nbsp;L1 or R1 Button</font>
				  <br>&nbsp; Center camera behind character -
                  <font color="#00FF00">&nbsp;L1 + R1 or L2 + R2 Buttons</font>
				  <br>&nbsp; Paddle -
                  <font color="#00FF00">&nbsp;X Button (when underwater)</font>
				  <br>&nbsp; Dive -
                  <font color="#00FF00">&nbsp;Square Button (when underwater)</font>				  
				  <br>&nbsp; Jump onto and climb up or down a ladder -
                  <font color="#00FF00">&nbsp;D-Pad + X Button</font>				  
				  <br>&nbsp; Headbash -
                  <font color="#00FF00">&nbsp;X + Triangle Button</font>
				  <br>&nbsp; Show status -
                  <font color="#00FF00">&nbsp;Select Button</font>				  
				  <br>&nbsp; Pause game -
                  <font color="#00FF00">&nbsp;Start Button</font><br><br>
				  &nbsp;</td>
	 </tr>
	</table>
