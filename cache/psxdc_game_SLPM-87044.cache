			<br>&nbsp;<u><i><font color="#FFFF00">BASIC CONTROLS:</font></i></u><br>
                  &nbsp; Move tank:
                  <font color="#00FF00">&nbsp;D-Pad or Left Analog Stick</font>
                  <br>&nbsp; Rotate cannon barrel:
                  <font color="#00FF00">&nbsp;Right Analog Stick</font>
                  <br>&nbsp; Move cannon barrel down:
                  <font color="#00FF00">&nbsp;X Button</font>
                  <br>&nbsp; Rotate cannon barrel left:
                  <font color="#00FF00">&nbsp;Square Button</font>
                  <br>&nbsp; Rotate cannon barrel right:
                  <font color="#00FF00">&nbsp;Circle Button</font>
                  <br>&nbsp; Move cannon barrel up:
                  <font color="#00FF00">&nbsp;Triangle Button</font>
                  <br>&nbsp; Turn tank rapidly:
                  <font color="#00FF00">&nbsp;L1 Button + D-Pad Left or Right</font>
                  <br>&nbsp; Charge energy for large attack:
                  <font color="#00FF00">&nbsp;L2 Button</font>
                  <br>&nbsp; Fire energy for small attack after charging:
                  <font color="#00FF00">&nbsp;R1 Button</font>
                  <br>&nbsp; Fire energy for large attack after charging:
                  <font color="#00FF00">&nbsp;R2 Button</font>
                  <br>&nbsp; Pause game:
                  <font color="#00FF00">&nbsp;Start Button</font><br><br>
    &nbsp;</td>
	 </tr>
