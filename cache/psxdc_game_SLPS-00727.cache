	<tr>
		<td style="font-family: Trebuchet MS; font-size: 8pt; color: #FFFFFF; font-weight: bold; text-align: left; background-color: #333333; border-left: 2px solid #000000; border-right: 2px solid #FFFFFF; border-top: 2px solid #000000; border-bottom: 2px solid #FFFFFF">
				  <br><u><i><font color="#FFFF00">MISC CODES:</font></i></u><br>
			        &nbsp; All Items Mapped -    
                  &nbsp; <font color="#00FF00">While paused press Triangle, Triangle, L2, R2, L2, R2, R1, Circle</font>&nbsp;
			        <br>&nbsp; All Weapons, Lots of Ammo and All Keys -    
                  &nbsp; <font color="#00FF00">While paused press X, Triangle, L1, Up, Down, R2, Left, Left</font>&nbsp;
			        <br>&nbsp; Full Map -    
                  &nbsp; <font color="#00FF00">While paused press Triangle, Triangle, L2, R2, L2, R2, R1, Square</font>&nbsp;
			        <br>&nbsp; God Mode -    
                  &nbsp; <font color="#00FF00">While paused press Down, L2, Square, R1, Right, L1, Left, Circle</font>&nbsp;
			        <br>&nbsp; Skip Current Level -    
                  &nbsp; <font color="#00FF00">While paused press Right, Left, R2, R1, Triangle, L1, Circle, X</font>&nbsp;
			        <br>&nbsp; Transparent Walls -    
                  &nbsp; <font color="#00FF00">While paused press L1, R2, L2, R1, Right, Triangle, X, Right</font>&nbsp;<br><br>				  
				  </tr>
	</table>
